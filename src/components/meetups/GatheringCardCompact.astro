---
import { formatTime, osmUrl } from "../../lib/utils";

interface Props {
  id: string;
  title: string;
  date: Date;
  time: string;
  venue: string;
  address?: string | null;
  city?: string | null;
  country?: string | null;
  eventContext?: string | null;
  capacity: number;
  rsvpCount: number;
  groupName: string;
}

const { id, title, date, time, venue, address, city, country, eventContext, capacity, rsvpCount, groupName } = Astro.props;

const spotsLeft = Math.max(0, capacity - rsvpCount);
const isFull = spotsLeft === 0;

const locationParts = [city, country].filter(Boolean).join(", ");
const locationLine = eventContext
  ? locationParts ? `${eventContext} · ${locationParts}` : eventContext
  : locationParts;
---

<article class="g-card">
  <div class="g-top">
    <div class="g-date">
      <span class="g-month">{new Intl.DateTimeFormat("en-US", { month: "short" }).format(date)}</span>
      <span class="g-day">{date.getDate()}</span>
    </div>
    <div class="g-info">
      <p class="g-group">{groupName}</p>
      <h3 class="g-title">{title}</h3>
      <p class="g-where">
        🕐 {formatTime(time)} · <a href={osmUrl(venue, address)} class="g-venue-link" target="_blank" rel="noopener noreferrer">{venue}</a>
        {locationLine && <span class="g-location"> · {locationLine}</span>}
      </p>
    </div>
  </div>

  <div class="g-footer">
    {isFull
      ? <span class="badge badge-full">Full</span>
      : <span class="g-spots"><strong>{spotsLeft}</strong> of {capacity} spots left</span>
    }
    {!isFull && <a href={`/gatherings/${id}/rsvp`} class="btn btn-primary btn-sm">RSVP →</a>}
  </div>
</article>

<style>
  .g-card {
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .g-top {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
  }

  .g-date {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: var(--color-primary);
    color: white;
    border-radius: var(--radius-sm);
    padding: 0.375rem 0.625rem;
    min-width: 46px;
    flex-shrink: 0;
    line-height: 1;
  }

  .g-month {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 700;
  }

  .g-day {
    font-family: var(--font-display);
    font-size: var(--size-2xl);
  }

  .g-info {
    flex: 1;
    min-width: 0;
  }

  .g-group {
    font-size: var(--size-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    margin-bottom: 0.2rem;
    max-width: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .g-title {
    font-size: var(--size-base);
    line-height: 1.3;
    margin-bottom: 0.375rem;
  }

  .g-where {
    font-size: var(--size-xs);
    color: var(--color-text-muted);
    max-width: none;
    line-height: 1.5;
  }

  .g-venue-link {
    color: inherit;
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 2px;
  }

  .g-venue-link:hover {
    color: var(--color-primary);
    text-decoration-style: solid;
  }

  .g-location { color: var(--color-text-light); }

  .g-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding-top: 0.75rem;
    border-top: 1px dashed var(--color-border);
    margin-top: auto;
  }

  .g-spots {
    font-size: var(--size-xs);
    color: var(--color-text-muted);
  }

  .g-spots strong { color: var(--color-accent-dark); }
</style>
