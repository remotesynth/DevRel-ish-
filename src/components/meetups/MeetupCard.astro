---
import { formatDate, formatTime, spotsLeft } from "../../lib/utils";

interface Props {
  id: string;
  title: string;
  description: string;
  date: Date;
  time: string;
  venue: string;
  address?: string | null;
  capacity: number;
  rsvpCount: number;
  groupSlug?: string;
}

const { id, title, description, date, time, venue, address, capacity, rsvpCount, groupSlug } = Astro.props;

const spots = spotsLeft(capacity, rsvpCount);
const isFull = spots === 0;
const snippet = description.length > 160 ? description.slice(0, 160) + "…" : description;
---

<article class="meetup-card card">
  <div class="meetup-meta">
    <div class="meetup-date-block">
      <span class="date-month">
        {new Intl.DateTimeFormat("en-US", { month: "short" }).format(date)}
      </span>
      <span class="date-day">{date.getDate()}</span>
    </div>
    <div class="meetup-info">
      <h3 class="meetup-title">{title}</h3>
      <p class="meetup-time">🕐 {formatTime(time)} &bull; 📍 {venue}</p>
    </div>
  </div>

  <p class="meetup-desc">{snippet}</p>

  <div class="meetup-footer">
    <div class="meetup-stats">
      {
        isFull ? (
          <span class="badge badge-full">Full</span>
        ) : (
          <span class="spots-left">
            <strong>{spots}</strong> of {capacity} spots left
          </span>
        )
      }
    </div>
    {
      !isFull && (
        <a href={`/meetups/${id}/rsvp`} class="btn btn-primary btn-sm">
          RSVP →
        </a>
      )
    }
  </div>
</article>

<style>
  .meetup-card {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .meetup-meta {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .meetup-date-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: var(--color-primary);
    color: white;
    border-radius: var(--radius-sm);
    padding: 0.375rem 0.75rem;
    min-width: 52px;
    flex-shrink: 0;
    line-height: 1;
  }

  .date-month {
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 700;
  }

  .date-day {
    font-family: var(--font-display);
    font-size: var(--size-2xl);
  }

  .meetup-info {
    flex: 1;
  }

  .meetup-title {
    font-size: var(--size-lg);
    line-height: 1.3;
  }

  .meetup-time {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    margin-top: 0.25rem;
    max-width: none;
  }

  .meetup-desc {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
  }

  .meetup-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px dashed var(--color-border);
  }

  .spots-left {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
  }

  .spots-left strong {
    color: var(--color-accent-dark);
  }
</style>
