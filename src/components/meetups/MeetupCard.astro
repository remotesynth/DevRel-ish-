---
import { formatDate, formatTime, spotsLeft, osmUrl } from "../../lib/utils";
import { renderMarkdown } from "../../lib/markdown";

interface Props {
  id: string;
  title: string;
  description: string;
  date: Date;
  time: string;
  venue: string;
  address?: string | null;
  capacity: number;
  rsvpCount: number;
  groupSlug?: string;
  status?: string;
  groupClosed?: boolean;
}

const { id, title, description, date, time, venue, address, capacity, rsvpCount, groupSlug, status = "active", groupClosed = false } = Astro.props;

const isCanceled = status === "canceled";
const spots = spotsLeft(capacity, rsvpCount);
const isFull = spots === 0;
const descHtml = renderMarkdown(description);
---

<article class:list={["meetup-card card", { canceled: isCanceled }]}>
  <div class="meetup-meta">
    <div class:list={["meetup-date-block", { "date-canceled": isCanceled }]}>
      <span class="date-month">
        {new Intl.DateTimeFormat("en-US", { month: "short" }).format(date)}
      </span>
      <span class="date-day">{date.getDate()}</span>
    </div>
    <div class="meetup-info">
      <h3 class="meetup-title">
        {title}
        {isCanceled && <span class="badge-canceled">Cancelled</span>}
      </h3>
      <p class="meetup-time">
        🕐 {formatTime(time)} &bull; 📍 <a href={osmUrl(venue, address)} class="venue-link" target="_blank" rel="noopener noreferrer">{venue}</a>
      </p>
    </div>
  </div>

  <div class="meetup-desc" set:html={descHtml} />

  <div class="meetup-footer">
    <div class="meetup-stats">
      {isCanceled ? (
        <span class="canceled-note">This gathering has been cancelled.</span>
      ) : isFull ? (
        <span class="badge badge-full">Full</span>
      ) : (
        <span class="spots-left">
          <strong>{spots}</strong> of {capacity} spots left
        </span>
      )}
    </div>
    {!isCanceled && !groupClosed && !isFull && (
      <a href={`/gatherings/${id}/rsvp`} class="btn btn-primary btn-sm">
        RSVP →
      </a>
    )}
  </div>
</article>

<style>
  .meetup-card {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .meetup-meta {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .meetup-card.canceled {
    opacity: 0.75;
  }

  .meetup-date-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: var(--color-primary);
    color: white;
    border-radius: var(--radius-sm);
    padding: 0.375rem 0.75rem;
    min-width: 52px;
    flex-shrink: 0;
    line-height: 1;
  }

  .meetup-date-block.date-canceled {
    background: var(--color-text-light);
  }

  .date-month {
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 700;
  }

  .date-day {
    font-family: var(--font-display);
    font-size: var(--size-2xl);
  }

  .meetup-info {
    flex: 1;
  }

  .meetup-title {
    font-size: var(--size-lg);
    line-height: 1.3;
  }

  .meetup-time {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    margin-top: 0.25rem;
    max-width: none;
  }

  .venue-link {
    color: inherit;
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 2px;
  }

  .venue-link:hover {
    color: var(--color-primary);
    text-decoration-style: solid;
  }

  .meetup-desc {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .meetup-desc :global(p) { margin: 0; }
  .meetup-desc :global(p + p) { margin-top: 0.375rem; }
  .meetup-desc :global(ul),
  .meetup-desc :global(ol) { padding-left: 1.25rem; margin: 0; }
  .meetup-desc :global(strong) { color: var(--color-text); }

  .meetup-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px dashed var(--color-border);
  }

  .spots-left {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
  }

  .spots-left strong {
    color: var(--color-accent-dark);
  }

  .badge-canceled {
    display: inline-block;
    font-size: var(--size-xs);
    font-weight: 700;
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    background: #fee2e2;
    color: #991b1b;
    border-radius: var(--radius-full);
    padding: 0.1rem 0.5rem;
    margin-left: 0.5rem;
    vertical-align: middle;
  }

  .canceled-note {
    font-size: var(--size-sm);
    color: #991b1b;
    font-weight: 600;
  }
</style>
