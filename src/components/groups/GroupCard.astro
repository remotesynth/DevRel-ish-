---
interface Props {
  id: string;
  name: string;
  slug: string;
  city?: string | null;
  region?: string | null;
  country?: string | null;
  tagline?: string | null;
  category?: string | null;
  tags?: string | null;
  description: string;
  upcomingCount?: number;
}

import { stripMarkdown } from "../../lib/markdown";
import { getCategoryLabel } from "../../lib/categories";

const { name, slug, city, region, country, tagline, category, tags, description, upcomingCount = 0 } = Astro.props;

const location = city
  ? region ? `${city}, ${region}` : country ? `${city}, ${country}` : city
  : null;

const tagList = tags ? tags.split(",").map(t => t.trim()).filter(Boolean) : [];

const plain = stripMarkdown(description);
const snippet = plain.length > 140 ? plain.slice(0, 140) + "…" : plain;
---

<article class="group-card card">
  <div class="card-header">
    <div class="group-icon" aria-hidden="true">◈</div>
    <div>
      {category && (
        <a href={`/groups?category=${encodeURIComponent(category)}`} class="category-badge">{getCategoryLabel(category) ?? category}</a>
      )}
      <h3 class="group-name">
        <a href={`/groups/${slug}`}>{name}</a>
      </h3>
      {tagline && <p class="group-tagline">{tagline}</p>}
      {location && <p class="group-location">📍 {location}</p>}
    </div>
  </div>

  <p class="group-desc">{snippet}</p>

  {tagList.length > 0 && (
    <div class="tag-list">
      {tagList.map(tag => (
        <a href={`/groups?tag=${encodeURIComponent(tag)}`} class="tag-chip">{tag}</a>
      ))}
    </div>
  )}

  <div class="card-footer">
    {
      upcomingCount > 0 ? (
        <span class="badge badge-upcoming">
          {upcomingCount} upcoming {upcomingCount === 1 ? "gathering" : "gatherings"}
        </span>
      ) : (
        <span class="no-meetups">No upcoming gatherings</span>
      )
    }
    <a href={`/groups/${slug}`} class="btn btn-ghost btn-sm">View group →</a>
  </div>
</article>

<style>
  .group-card {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .card-header {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
  }

  .group-icon {
    font-size: 1.75rem;
    color: var(--color-primary);
    flex-shrink: 0;
    line-height: 1;
    margin-top: 0.125rem;
  }

  .group-name {
    font-size: var(--size-lg);
    line-height: 1.3;
  }

  .group-name a {
    text-decoration: none;
    color: var(--color-text);
  }

  .group-name a:hover {
    color: var(--color-primary);
  }

  .category-badge {
    display: inline-block;
    font-size: var(--size-xs);
    font-weight: 700;
    background: rgba(124, 58, 237, 0.08);
    color: #7c3aed;
    border: 1px solid rgba(124, 58, 237, 0.2);
    border-radius: var(--radius-full);
    padding: 0.1rem 0.55rem;
    margin-bottom: 0.3rem;
    text-decoration: none;
    transition: background var(--transition), border-color var(--transition);
  }

  .category-badge:hover {
    background: rgba(124, 58, 237, 0.15);
    border-color: rgba(124, 58, 237, 0.4);
  }

  .group-tagline {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    font-style: italic;
    margin-top: 0.125rem;
    max-width: none;
  }

  .group-location {
    font-size: var(--size-xs);
    color: var(--color-text-light);
    margin-top: 0.125rem;
    max-width: none;
  }

  .group-desc {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .tag-chip {
    font-size: var(--size-xs);
    font-weight: 600;
    background: var(--color-surface-warm);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 0.15rem 0.6rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition), border-color var(--transition), background var(--transition);
  }

  .tag-chip:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
    background: rgba(232, 112, 74, 0.06);
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: auto;
    padding-top: 0.5rem;
    border-top: 1px dashed var(--color-border);
  }

  .no-meetups {
    font-size: var(--size-xs);
    color: var(--color-text-light);
    font-style: italic;
  }
</style>
