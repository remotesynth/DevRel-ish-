  .footer-nav a {
    font-size: var(--size-sm);
    font-weight: 600;
    text-decoration: none;
    color: var(--color-text-muted);
  }

  .footer-nav a:hover {
    color: var(--color-primary);
  }

  .footer-bottom p {
    font-size: var(--size-xs);
    color: var(--color-text-light);
    max-width: none;
