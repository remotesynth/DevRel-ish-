---
import { db, ContactMessages, count, eq, and } from "astro:db";

interface Props {
  user: App.Locals["user"];
}
const { user } = Astro.props;
const path = Astro.url.pathname;
const isAdmin = user?.role === "admin";

let unreadMessages = 0;
if (!isAdmin && user?.groupId) {
  const [result] = await db
    .select({ val: count() })
    .from(ContactMessages)
    .where(and(eq(ContactMessages.groupId, user.groupId), eq(ContactMessages.read, false)));
  unreadMessages = result?.val ?? 0;
}

function isActive(href: string) {
  return path === href || path.startsWith(href + "/");
}
---

<aside class="dash-nav">
  <div class="dash-nav-inner">
    <a href="/" class="dash-logo">
      DevRel<span class="logo-ish">(ish)</span>
    </a>

    <div class="dash-user">
      <div class="user-avatar" aria-hidden="true">
        {user?.name?.[0]?.toUpperCase() ?? "?"}
      </div>
      <div>
        <p class="user-name">{user?.name}</p>
        <p class="user-email">{user?.email}</p>
      </div>
    </div>

    <nav aria-label="Dashboard navigation">
      {
        isAdmin ? (
          <ul class="dash-menu" role="list">
            <li>
              <a href="/admin" class:list={["dash-link", { active: isActive("/admin") && path === "/admin" }]}>
                ✦ Pending Groups
              </a>
            </li>
            <li>
              <a href="/admin/groups" class:list={["dash-link", { active: isActive("/admin/groups") }]}>
                ◈ All Groups
              </a>
            </li>
          </ul>
        ) : (
          <ul class="dash-menu" role="list">
            <li>
              <a href="/dashboard" class:list={["dash-link", { active: path === "/dashboard" }]}>
                ◎ Overview
              </a>
            </li>
            <li>
              <a href="/dashboard/group" class:list={["dash-link", { active: isActive("/dashboard/group") }]}>
                ◈ My Group
              </a>
            </li>
            <li>
              <a href="/dashboard/meetups" class:list={["dash-link", { active: isActive("/dashboard/meetups") }]}>
                ✦ Meetups
              </a>
            </li>
            <li>
              <a href="/dashboard/messages" class:list={["dash-link", { active: isActive("/dashboard/messages") }]}>
                <span class="nav-link-inner">
                  ✉ Messages
                  {unreadMessages > 0 && <span class="nav-badge">{unreadMessages}</span>}
                </span>
              </a>
            </li>
            <li>
              <a href="/dashboard/team" class:list={["dash-link", { active: isActive("/dashboard/team") }]}>
                ◎ Team
              </a>
            </li>
          </ul>
        )
      }
    </nav>

    <div class="dash-nav-footer">
      <a href="/" class="dash-link dash-link-sm">← Public site</a>
      <a href="/auth/signout" class="dash-link dash-link-sm">Sign out</a>
    </div>
  </div>
</aside>

<style>
  .dash-nav {
    width: 240px;
    min-height: 100vh;
    background: var(--color-surface);
    border-right: 2px solid var(--color-border);
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
  }

  .dash-nav-inner {
    position: sticky;
    top: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 1.5rem 1rem;
    height: 100vh;
    overflow-y: auto;
  }

  .dash-logo {
    font-family: var(--font-display);
    font-size: var(--size-xl);
    color: var(--color-primary);
    text-decoration: none;
    display: block;
  }

  .logo-ish {
    color: var(--color-text-muted);
    font-size: 0.85em;
  }

  .dash-user {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem;
    background: var(--color-surface-warm);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
  }

  .user-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-primary);
    color: white;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--size-sm);
    flex-shrink: 0;
  }

  .user-name {
    font-weight: 700;
    font-size: var(--size-sm);
    line-height: 1.3;
    max-width: none;
  }

  .user-email {
    font-size: var(--size-xs);
    color: var(--color-text-muted);
    max-width: none;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .dash-menu {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .dash-link {
    display: block;
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition:
      color var(--transition),
      background-color var(--transition);
    background: none;
    border: none;
    cursor: pointer;
    width: 100%;
    text-align: left;
  }

  .dash-link:hover,
  .dash-link.active {
    color: var(--color-primary);
    background: var(--color-surface-warm);
  }

  .dash-link-sm {
    font-size: var(--size-xs);
    padding: 0.375rem 0.75rem;
  }

  .nav-link-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .nav-badge {
    font-size: 10px;
    font-weight: 700;
    background: var(--color-primary);
    color: white;
    border-radius: var(--radius-full);
    padding: 0.1rem 0.4rem;
    line-height: 1.4;
    flex-shrink: 0;
  }

  .dash-nav-footer {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    border-top: 1px dashed var(--color-border);
    padding-top: 1rem;
  }

  @media (max-width: 768px) {
    .dash-nav {
      width: 100%;
      min-height: auto;
    }

    .dash-nav-inner {
      height: auto;
      position: static;
    }

    .dash-menu {
      flex-direction: row;
      flex-wrap: wrap;
    }
  }
</style>
