---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
import { db, Groups, GroupInvites, User } from "astro:db";
import { eq } from "astro:db";
import { generateId } from "../../../lib/utils";

if (!Astro.locals.user) return Astro.redirect("/auth/login");
if (Astro.locals.user.role !== "admin") return Astro.redirect("/dashboard");

const user = Astro.locals.user;

const { id } = Astro.params;
if (!id) return Astro.redirect("/admin");

const [group] = await db.select().from(Groups).where(eq(Groups.id, id));
if (!group) return Astro.redirect("/admin");

let successMsg = "";
let errorMsg = "";
let approvalInviteUrl = ""; // set after approve or regenerate_invite

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("action")?.toString();

  if (action === "regenerate_invite") {
    await db.delete(GroupInvites).where(eq(GroupInvites.groupId, id));
    const token = generateId();
    await db.insert(GroupInvites).values({
      id: token,
      groupId: id,
      createdAt: new Date(),
      expiresAt: new Date(Date.now() + 7 * 24 * 60 * 60 * 1000),
    });
    approvalInviteUrl = `${Astro.url.origin}/invite/${token}`;
  } else {
    const statusMap: Record<string, string> = {
      approve: "approved",
      reject: "rejected",
      close: "closed",
      reopen: "approved",
    };

    if (action && action in statusMap) {
      try {
        const res = await fetch(`${Astro.url.origin}/api/groups/${id}/status`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            cookie: Astro.request.headers.get("cookie") ?? "",
          },
          body: JSON.stringify({ id, status: statusMap[action] }),
        });

        if (res.ok) {
          const msgs: Record<string, string> = {
            reject: "Group application rejected.",
            close: "Group closed. It will no longer appear in public listings.",
            reopen: "Group reopened and is now publicly visible again.",
          };
          successMsg = msgs[action] ?? "Done.";

          const [updated] = await db.select().from(Groups).where(eq(Groups.id, id));
          if (updated) Object.assign(group, updated);

          if (action === "approve") {
            await db.delete(GroupInvites).where(eq(GroupInvites.groupId, id));
            const token = generateId();
            await db.insert(GroupInvites).values({
              id: token,
              groupId: id,
              createdAt: new Date(),
              expiresAt: new Date(Date.now() + 7 * 24 * 60 * 60 * 1000),
            });
            approvalInviteUrl = `${Astro.url.origin}/invite/${token}`;
          }
        } else {
          errorMsg = "Action failed. Please try again.";
        }
      } catch {
        errorMsg = "Something went wrong.";
      }
    }
  }
}

// Team members and active invite (queried after POST so state is current)
const members = await db.select().from(User).where(eq(User.groupId, id));
const isUnclaimed = group.status === "approved" && members.length === 0;

const now = new Date();
const [activeInviteRow] = await db
  .select()
  .from(GroupInvites)
  .where(eq(GroupInvites.groupId, id));
const activeInvite = activeInviteRow && activeInviteRow.expiresAt > now ? activeInviteRow : null;
const existingInviteUrl = activeInvite ? `${Astro.url.origin}/invite/${activeInvite.id}` : "";
---

<DashboardLayout title={`Review — ${group.name}`}>
  <div class="page-header">
    <a href="/admin" class="back-link">← Back to admin</a>
    <div class="header-row">
      <h1>{group.name}</h1>
      <span class:list={["badge", `badge-${group.status}`]}>
        {group.status}
      </span>
    </div>
  </div>

  {approvalInviteUrl ? (
    <div class="approval-panel">
      <div class="approval-header">
        <span class="approval-check">✓</span>
        <div>
          <strong>Group approved!</strong>
          <p>Copy the email below and send it to <strong>{group.contactEmail}</strong>.</p>
        </div>
      </div>

      <div class="email-template">
        <div class="email-template-header">
          <span class="email-label">Email to send</span>
          <button type="button" id="copy-email-btn" class="btn btn-ghost btn-sm">Copy</button>
        </div>
        <pre id="email-body" class="email-body">{`Hi there,

Great news — your DevRel(ish) group "${group.name}" has been approved!

You can now create your organizer account and start setting up meetups. Use the link below to get started — it'll walk you through creating your account and give you access to the dashboard.

${approvalInviteUrl}

This link expires in 7 days. If it expires before you use it, just reply to this email and I'll send a new one.

Welcome to the community!`}</pre>
      </div>

      <p class="approval-hint">
        The invite link is also saved — you can find it again under the group's public page or regenerate it from the organizer's Team page.
      </p>
    </div>
  ) : successMsg ? (
    <div class="alert alert-success">{successMsg}</div>
  ) : null}
  {errorMsg && <div class="alert alert-error">{errorMsg}</div>}

  <div class="review-layout">
    <div class="review-main">
      <div class="detail-card">
        <h3>Group details</h3>
        <dl class="detail-list">
          <dt>Name</dt>
          <dd>{group.name}</dd>

          <dt>Location</dt>
          <dd>
            {group.region
              ? `${group.city}, ${group.region}, ${group.country}`
              : `${group.city}, ${group.country}`}
          </dd>

          <dt>Contact email</dt>
          <dd><a href={`mailto:${group.contactEmail}`}>{group.contactEmail}</a></dd>

          <dt>Applied</dt>
          <dd>
            {new Intl.DateTimeFormat("en-US", {
              dateStyle: "long",
            }).format(group.createdAt)}
          </dd>

        </dl>
      </div>

      <div class="detail-card">
        <h3>Description</h3>
        <p class="description-text">{group.description}</p>
      </div>

      {group.status !== "pending" && (
        <div class="detail-card">
          <h3>
            Organizers
            {isUnclaimed && <span class="badge-unclaimed">Unclaimed</span>}
          </h3>
          {members.length === 0 ? (
            <p class="no-members">
              No one has claimed this group yet. Use the invite link in the action panel to send them access.
            </p>
          ) : (
            <ul class="member-list">
              {members.map((m) => (
                <li class="member-item">
                  <div class="member-avatar">{m.name?.[0]?.toUpperCase() ?? "?"}</div>
                  <div class="member-info">
                    <strong>{m.name}</strong>
                    <a href={`mailto:${m.email}`} class="member-email">{m.email}</a>
                  </div>
                </li>
              ))}
            </ul>
          )}
        </div>
      )}
    </div>

    {
      group.status === "pending" && (
        <div class="action-card">
          <h3>Take action</h3>
          <p>Once approved, this group will appear publicly and the contact can sign in to manage meetups.</p>

          <div class="action-btns">
            <form method="POST">
              <input type="hidden" name="action" value="approve" />
              <button type="submit" class="btn btn-accent btn-lg">
                ✓ Approve group
              </button>
            </form>
            <form method="POST">
              <input type="hidden" name="action" value="reject" />
              <button type="submit" class="btn btn-danger">
                ✗ Reject application
              </button>
            </form>
          </div>
        </div>
      )
    }

    {
      group.status !== "pending" && (
        <div class="action-card">
          <h3>Status</h3>
          <p>
            This group is <strong>{group.status}</strong>.
          </p>
          <div class="action-btns">
            {group.status === "approved" && (
              <>
                {isUnclaimed && (
                  <div class="invite-section">
                    <p class="invite-section-label">
                      {approvalInviteUrl || existingInviteUrl
                        ? "Invite link — share with the organizer:"
                        : "No active invite link."}
                    </p>
                    {(approvalInviteUrl || existingInviteUrl) && (
                      <div class="invite-url-row">
                        <input
                          id="regen-invite-url"
                          type="text"
                          value={approvalInviteUrl || existingInviteUrl}
                          readonly
                          class="invite-input"
                        />
                        <button type="button" id="copy-invite-btn" class="btn btn-ghost btn-sm">Copy</button>
                      </div>
                    )}
                    <form method="POST">
                      <input type="hidden" name="action" value="regenerate_invite" />
                      <button type="submit" class="btn btn-accent btn-sm">
                        {approvalInviteUrl || existingInviteUrl ? "Regenerate link" : "Generate invite link →"}
                      </button>
                    </form>
                  </div>
                )}
                <a href={`/groups/${group.slug}`} class="btn btn-ghost" target="_blank" rel="noopener">
                  View public page ↗
                </a>
                <form method="POST">
                  <input type="hidden" name="action" value="close" />
                  <button type="submit" class="btn btn-danger">
                    Close group
                  </button>
                </form>
              </>
            )}
            {group.status === "closed" && (
              <>
                <a href={`/groups/${group.slug}`} class="btn btn-ghost" target="_blank" rel="noopener">
                  View group page ↗
                </a>
                <form method="POST">
                  <input type="hidden" name="action" value="reopen" />
                  <button type="submit" class="btn btn-accent">
                    Reopen group
                  </button>
                </form>
              </>
            )}
            {group.status === "rejected" && (
              <form method="POST">
                <input type="hidden" name="action" value="approve" />
                <button type="submit" class="btn btn-accent">
                  ✓ Approve anyway
                </button>
              </form>
            )}
          </div>
        </div>
      )
    }
  </div>
</DashboardLayout>

<style>
  .page-header {
    margin-bottom: 1.75rem;
  }

  .back-link {
    font-size: var(--size-sm);
    font-weight: 600;
    text-decoration: none;
    color: var(--color-text-muted);
    display: block;
    margin-bottom: 0.75rem;
  }

  .back-link:hover {
    color: var(--color-primary);
  }

  .header-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .header-row h1 {
    font-size: var(--size-3xl);
  }

  .alert {
    margin-bottom: 1.25rem;
  }

  .review-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 1.5rem;
    align-items: start;
  }

  .review-main {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .detail-card {
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
  }

  .detail-card h3 {
    font-size: var(--size-lg);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px dashed var(--color-border);
  }

  .detail-list {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 0.5rem 1rem;
  }

  .detail-list dt {
    font-size: var(--size-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    padding-top: 0.125rem;
  }

  .detail-list dd {
    font-size: var(--size-sm);
    color: var(--color-text);
  }

  .description-text {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  /* Action card */
  .action-card {
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    position: sticky;
    top: 80px;
  }

  .action-card h3 {
    font-size: var(--size-base);
    margin-bottom: 0.625rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px dashed var(--color-border);
  }

  .action-card p {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .action-btns {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .action-btns form {
    display: contents;
  }

  /* Approval panel */
  .approval-panel {
    background: #f0fdf4;
    border: 2px solid #86efac;
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .approval-header {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
  }

  .approval-check {
    font-size: var(--size-lg);
    font-weight: 700;
    color: #16a34a;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .approval-header strong {
    display: block;
    color: #15803d;
    font-size: var(--size-base);
    margin-bottom: 0.125rem;
  }

  .approval-header p {
    font-size: var(--size-sm);
    color: #166534;
    margin: 0;
    max-width: none;
  }

  .email-template {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .email-template-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.625rem 1rem;
    border-bottom: 1px dashed var(--color-border);
  }

  .email-label {
    font-size: var(--size-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .email-body {
    font-family: var(--font-body, sans-serif);
    font-size: var(--size-sm);
    color: var(--color-text);
    line-height: 1.7;
    white-space: pre-wrap;
    padding: 1rem;
    margin: 0;
  }

  .approval-hint {
    font-size: var(--size-xs);
    color: #166534;
    margin: 0;
    max-width: none;
  }

  /* Organizers card */
  .badge-unclaimed {
    display: inline-block;
    font-size: var(--size-xs);
    font-weight: 700;
    background: rgba(234, 179, 8, 0.15);
    color: #854d0e;
    border-radius: var(--radius-full);
    padding: 0.15rem 0.5rem;
    margin-left: 0.5rem;
    vertical-align: middle;
  }

  .no-members {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    margin: 0;
    max-width: none;
  }

  .member-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .member-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem;
    background: var(--color-surface-warm);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
  }

  .member-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--color-primary);
    color: white;
    font-weight: 700;
    font-size: var(--size-xs);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .member-info {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .member-info strong {
    font-size: var(--size-sm);
  }

  .member-email {
    font-size: var(--size-xs);
    color: var(--color-text-muted);
  }

  /* Invite section inside action card */
  .invite-section {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.75rem;
    background: rgba(234, 179, 8, 0.08);
    border: 1px solid rgba(234, 179, 8, 0.3);
    border-radius: var(--radius-md);
  }

  .invite-section-label {
    font-size: var(--size-xs);
    font-weight: 700;
    color: #854d0e;
    margin: 0;
    max-width: none;
  }

  .invite-url-row {
    display: flex;
    gap: 0.375rem;
    align-items: center;
  }

  .invite-input {
    flex: 1;
    font-size: 11px;
    font-family: var(--font-mono, monospace);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.375rem 0.5rem;
    color: var(--color-text);
    min-width: 0;
  }

  @media (max-width: 768px) {
    .review-layout {
      grid-template-columns: 1fr;
    }

    .action-card {
      position: static;
    }
  }
</style>

<script>
  function setupCopy(btnId: string, getText: () => string) {
    const btn = document.getElementById(btnId) as HTMLButtonElement | null;
    if (!btn) return;
    btn.addEventListener("click", () => {
      const text = getText();
      navigator.clipboard.writeText(text).then(() => {
        btn.textContent = "Copied!";
        setTimeout(() => { btn.textContent = "Copy"; }, 2500);
      }).catch(() => {
        const ta = document.createElement("textarea");
        ta.value = text;
        ta.style.position = "fixed";
        ta.style.opacity = "0";
        document.body.appendChild(ta);
        ta.focus();
        ta.select();
        document.execCommand("copy");
        document.body.removeChild(ta);
        btn.textContent = "Copied!";
        setTimeout(() => { btn.textContent = "Copy"; }, 2500);
      });
    });
  }

  setupCopy("copy-email-btn", () => {
    return (document.getElementById("email-body") as HTMLElement | null)?.textContent ?? "";
  });

  setupCopy("copy-invite-btn", () => {
    return (document.getElementById("regen-invite-url") as HTMLInputElement | null)?.value ?? "";
  });
</script>
