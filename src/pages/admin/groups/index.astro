---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
import { db, Groups } from "astro:db";
import { desc } from "astro:db";

if (!Astro.locals.user) return Astro.redirect("/auth/login");
if (Astro.locals.user.role !== "admin") return Astro.redirect("/dashboard");

const allGroups = await db
  .select()
  .from(Groups)
  .orderBy(desc(Groups.createdAt));

const statusOrder: Record<string, number> = { pending: 0, approved: 1, closed: 2, rejected: 3 };
const grouped = allGroups.slice().sort((a, b) => {
  const sa = statusOrder[a.status] ?? 9;
  const sb = statusOrder[b.status] ?? 9;
  return sa !== sb ? sa - sb : 0;
});
---

<DashboardLayout title="All Groups">
  <div class="page-header">
    <h1>
      All Groups
      <span class="count-badge">{allGroups.length}</span>
    </h1>
    <p>All groups across every status.</p>
  </div>

  {allGroups.length === 0 ? (
    <div class="empty-state">
      <p>No groups yet.</p>
    </div>
  ) : (
    <div class="groups-table">
      <div class="table-header">
        <span>Group</span>
        <span>Location</span>
        <span>Status</span>
        <span></span>
      </div>
      {grouped.map((g) => (
        <div class="table-row">
          <div class="cell-name">
            <strong>{g.name}</strong>
            <span class="cell-email">{g.contactEmail}</span>
          </div>
          <div class="cell-location">
            {g.region ? `${g.city}, ${g.region}, ${g.country}` : `${g.city}, ${g.country}`}
          </div>
          <div class="cell-status">
            <span class={`badge badge-${g.status}`}>{g.status}</span>
          </div>
          <div class="cell-action">
            <a href={`/admin/groups/${g.id}`} class="btn btn-ghost btn-sm">
              Manage →
            </a>
          </div>
        </div>
      ))}
    </div>
  )}
</DashboardLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-size: var(--size-3xl);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.25rem;
  }

  .page-header p {
    color: var(--color-text-muted);
  }

  .count-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-border-strong);
    color: var(--color-text-muted);
    border-radius: var(--radius-full);
    font-size: var(--size-xs);
    font-family: var(--font-body);
    font-weight: 700;
    min-width: 22px;
    height: 22px;
    padding: 0 6px;
  }

  .empty-state {
    padding: 2rem;
    background: var(--color-surface);
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .empty-state p {
    color: var(--color-text-muted);
    max-width: none;
  }

  .groups-table {
    display: flex;
    flex-direction: column;
    border: 2px solid var(--color-border-strong);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .table-header,
  .table-row {
    display: grid;
    grid-template-columns: 1fr 1fr auto auto;
    gap: 1rem;
    align-items: center;
    padding: 0.75rem 1.25rem;
  }

  .table-header {
    background: var(--color-surface-warm);
    border-bottom: 2px solid var(--color-border);
    font-size: var(--size-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
  }

  .table-row {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
  }

  .table-row:last-child {
    border-bottom: none;
  }

  .table-row:hover {
    background: var(--color-surface-warm);
  }

  .cell-name {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .cell-email {
    font-size: var(--size-xs);
    color: var(--color-text-muted);
  }

  .cell-location {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
  }

  .cell-status {
    display: flex;
  }

  .cell-action {
    display: flex;
    justify-content: flex-end;
  }

  .badge {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-full);
    font-size: var(--size-xs);
    font-weight: 700;
    text-transform: capitalize;
  }

  .badge-pending {
    background: rgba(234, 179, 8, 0.15);
    color: #854d0e;
  }

  .badge-approved {
    background: rgba(34, 197, 94, 0.15);
    color: #166534;
  }

  .badge-closed {
    background: #f3f4f6;
    color: #374151;
  }

  .badge-rejected {
    background: rgba(239, 68, 68, 0.12);
    color: #991b1b;
  }
</style>
