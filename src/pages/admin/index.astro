---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { db, Groups } from "astro:db";
import { eq, desc } from "astro:db";

if (!Astro.locals.user) return Astro.redirect("/auth/login");
if (Astro.locals.user.role !== "admin") return Astro.redirect("/dashboard");

const pendingGroups = await db
  .select()
  .from(Groups)
  .where(eq(Groups.status, "pending"))
  .orderBy(desc(Groups.createdAt));
---

<DashboardLayout title="Pending Groups">
  <div class="page-header">
    <h1>
      Pending applications
      {pendingGroups.length > 0 && (
        <span class="count-badge">{pendingGroups.length}</span>
      )}
    </h1>
    <p>Review and approve new group applications.</p>
  </div>

  {pendingGroups.length === 0 ? (
    <div class="empty-state">
      <p>No pending applications. You're all caught up! ✦</p>
    </div>
  ) : (
    <div class="groups-list">
      {pendingGroups.map((g) => (
        <div class="group-row">
          <div class="group-info">
            <h3 class="group-name">{g.name}</h3>
            <p class="group-location">
              📍 {g.region ? `${g.city}, ${g.region}, ${g.country}` : `${g.city}, ${g.country}`}
            </p>
            <p class="group-contact">✉️ {g.contactEmail}</p>
            <p class="group-desc">{g.description.slice(0, 200)}{g.description.length > 200 ? "…" : ""}</p>
          </div>
          <div class="group-actions">
            <a href={`/admin/groups/${g.id}`} class="btn btn-ghost btn-sm">
              Review →
            </a>
          </div>
        </div>
      ))}
    </div>
  )}
</DashboardLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-size: var(--size-3xl);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.25rem;
  }

  .page-header p {
    color: var(--color-text-muted);
  }

  .count-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary);
    color: white;
    border-radius: var(--radius-full);
    font-size: var(--size-xs);
    font-family: var(--font-body);
    font-weight: 700;
    min-width: 22px;
    height: 22px;
    padding: 0 6px;
  }

  .empty-state {
    padding: 2rem;
    background: var(--color-surface);
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .empty-state p {
    color: var(--color-text-muted);
    max-width: none;
  }

  .groups-list {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .group-row {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    background: var(--color-surface);
    border: 2px solid var(--color-border-strong);
    border-left: 4px solid var(--color-secondary);
    border-radius: var(--radius-md);
    padding: 1.25rem;
  }

  .group-info {
    flex: 1;
  }

  .group-name {
    font-size: var(--size-lg);
    margin-bottom: 0.25rem;
  }

  .group-location,
  .group-contact {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    max-width: none;
    margin-bottom: 0.125rem;
  }

  .group-desc {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    margin-top: 0.5rem;
    line-height: 1.5;
  }

  .group-actions {
    flex-shrink: 0;
  }
</style>
