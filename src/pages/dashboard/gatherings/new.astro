---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
import { db, Groups, Meetups } from "astro:db";
import { eq } from "astro:db";
import { generateId } from "../../../lib/utils";

if (!Astro.locals.user) return Astro.redirect("/auth/login");
const user = Astro.locals.user;

const [group] = user.groupId
  ? await db.select().from(Groups).where(eq(Groups.id, user.groupId))
  : [];

if (!group) return Astro.redirect("/dashboard");

type FormError = { type: "error"; message: string };
let error: FormError | null = null;

// Preserve form values on validation failure
let vals = {
  title: "",
  description: "",
  date: "",
  time: "18:00",
  venue: "",
  address: "",
  city: "",
  country: "",
  eventContext: "",
  tags: "",
  capacity: "30",
};

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();

  vals = {
    title: form.get("title")?.toString().trim() ?? "",
    description: form.get("description")?.toString().trim() ?? "",
    date: form.get("date")?.toString() ?? "",
    time: form.get("time")?.toString() ?? "18:00",
    venue: form.get("venue")?.toString().trim() ?? "",
    address: form.get("address")?.toString().trim() ?? "",
    city: form.get("city")?.toString().trim() ?? "",
    country: form.get("country")?.toString().trim() ?? "",
    eventContext: form.get("eventContext")?.toString().trim() ?? "",
    tags: form.get("tags")?.toString().trim() ?? "",
    capacity: form.get("capacity")?.toString() ?? "30",
  };

  const cap = Number(vals.capacity);
  const meetupDate = new Date(vals.date);

  if (!vals.title || !vals.description || !vals.date || !vals.time || !vals.venue || !vals.capacity) {
    error = { type: "error", message: "All required fields must be filled in." };
  } else if (vals.description.length < 20) {
    error = { type: "error", message: "Description must be at least 20 characters." };
  } else if (isNaN(meetupDate.getTime())) {
    error = { type: "error", message: "Invalid date." };
  } else if (meetupDate < new Date()) {
    error = { type: "error", message: "Gathering date must be in the future." };
  } else if (!Number.isInteger(cap) || cap < 1 || cap > 500) {
    error = { type: "error", message: "Capacity must be between 1 and 500." };
  } else {
    await db.insert(Meetups).values({
      id: generateId(),
      groupId: group.id,
      title: vals.title,
      description: vals.description,
      date: meetupDate,
      time: vals.time,
      venue: vals.venue,
      address: vals.address || null,
      city: vals.city || null,
      country: vals.country || null,
      eventContext: vals.eventContext || null,
      tags: vals.tags || null,
      capacity: cap,
      createdAt: new Date(),
    });
    return Astro.redirect("/dashboard/gatherings?created=1");
  }
}
---

<DashboardLayout title="New Gathering">
  <div class="page-header">
    <a href="/dashboard/gatherings" class="back-link">← Back to gatherings</a>
    <h1>Schedule a gathering</h1>
    <p>Fill in the details for your next gathering.</p>
  </div>

  <div class="form-wrap">
    <form method="POST" class="meetup-form">
      {error && (
        <div class="alert alert-error" role="alert">{error.message}</div>
      )}

      <div class="form-group">
        <label for="title">Gathering title *</label>
        <input id="title" name="title" type="text" value={vals.title} placeholder="Spring Social Gathering" required maxlength="100" />
      </div>

      <div class="form-group">
        <label for="description">Description *</label>
        <textarea id="description" name="description" rows="5" placeholder="What will you do? What's the vibe? Who should come?" required minlength="20" maxlength="2000">{vals.description}</textarea>
        <span class="form-hint">Markdown supported: **bold**, *italic*, # headings, - lists, [links](url).</span>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="date">Date *</label>
          <input id="date" name="date" type="date" value={vals.date} required min={new Date().toISOString().split("T")[0]} />
        </div>
        <div class="form-group">
          <label for="time">Time *</label>
          <input id="time" name="time" type="time" value={vals.time} required />
        </div>
      </div>

      <div class="form-group">
        <label for="venue">Venue name *</label>
        <input id="venue" name="venue" type="text" value={vals.venue} placeholder="The Interval at Long Now" required />
      </div>

      <div class="form-group">
        <label for="address">Address</label>
        <input id="address" name="address" type="text" value={vals.address} placeholder="2 Marina Blvd, San Francisco, CA 94123" />
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="city">City</label>
          <input id="city" name="city" type="text" value={vals.city} placeholder="San Francisco" />
        </div>
        <div class="form-group">
          <label for="country">Country</label>
          <input id="country" name="country" type="text" value={vals.country} placeholder="USA" />
        </div>
      </div>

      <div class="form-group">
        <label for="eventContext">Event context</label>
        <input id="eventContext" name="eventContext" type="text" value={vals.eventContext} placeholder="KubeCon EU 2026" />
        <span class="form-hint">If this gathering is tied to a conference or larger event, name it here.</span>
      </div>

      <div class="form-group">
        <label for="tags">Tags</label>
        <input id="tags" name="tags" type="text" value={vals.tags} placeholder="community, enterprise" />
        <span class="form-hint">Comma-separated. Helps people discover this gathering.</span>
      </div>

      <div class="form-group">
        <label for="capacity">Capacity *</label>
        <input id="capacity" name="capacity" type="number" value={vals.capacity} min="1" max="500" required />
        <span class="form-hint">How many people can attend?</span>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Create gathering →</button>
        <a href="/dashboard/gatherings" class="btn btn-ghost">Cancel</a>
      </div>
    </form>
  </div>
</DashboardLayout>

<style>
  .page-header {
    margin-bottom: 1.75rem;
  }

  .back-link {
    font-size: var(--size-sm);
    font-weight: 600;
    text-decoration: none;
    color: var(--color-text-muted);
    display: block;
    margin-bottom: 0.75rem;
  }

  .back-link:hover {
    color: var(--color-primary);
  }

  .page-header h1 {
    font-size: var(--size-3xl);
    margin-bottom: 0.25rem;
  }

  .page-header p {
    color: var(--color-text-muted);
  }

  .form-wrap .meetup-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    max-width: 600px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-actions {
    display: flex;
    gap: 0.875rem;
    align-items: center;
  }

  @media (max-width: 480px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
