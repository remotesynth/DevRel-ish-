---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
import { db, Groups, Meetups, RSVPs, count, eq, desc } from "astro:db";
import { formatDate, formatTime } from "../../../lib/utils";

if (!Astro.locals.user) return Astro.redirect("/auth/login");
const user = Astro.locals.user;

const [group] = user.groupId
  ? await db.select().from(Groups).where(eq(Groups.id, user.groupId))
  : [];

if (!group) return Astro.redirect("/dashboard");

const meetups = await db
  .select()
  .from(Meetups)
  .where(eq(Meetups.groupId, group.id))
  .orderBy(desc(Meetups.date));

const rsvpCounts: Record<string, number> = {};
for (const m of meetups) {
  const [r] = await db.select({ val: count() }).from(RSVPs).where(eq(RSVPs.meetupId, m.id));
  rsvpCounts[m.id] = r?.val ?? 0;
}

const today = new Date();
today.setHours(0, 0, 0, 0);

const justCreated = Astro.url.searchParams.get("created") === "1";
---

<DashboardLayout title="Gatherings">
  <div class="page-header">
    <h1>Gatherings</h1>
    <a href="/dashboard/gatherings/new" class="btn btn-primary">+ New gathering</a>
  </div>

  {justCreated && (
    <div class="alert alert-success" role="status">Gathering created successfully!</div>
  )}

  {
    meetups.length === 0 ? (
      <div class="empty-state">
        <div class="empty-icon" aria-hidden="true">✦</div>
        <h2>No gatherings yet</h2>
        <p>Schedule your first gathering and start collecting RSVPs!</p>
        <a href="/dashboard/gatherings/new" class="btn btn-primary">
          Create your first gathering →
        </a>
      </div>
    ) : (
      <div class="meetups-table-wrap">
        <table class="meetups-table">
          <thead>
            <tr>
              <th>Gathering</th>
              <th>Date &amp; Time</th>
              <th>Venue</th>
              <th>RSVPs</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {meetups.map((m) => {
              const isPast = m.date < today;
              const isCanceled = m.status === "canceled";
              return (
                <tr class:list={[{ past: isPast }, { canceled: isCanceled }]}>
                  <td>
                    <span class="meetup-title">{m.title}</span>
                    {isCanceled && <span class="badge-canceled">Cancelled</span>}
                    {!isCanceled && isPast && <span class="badge badge-past">Past</span>}
                  </td>
                  <td class="nowrap">
                    {formatDate(m.date)}<br />
                    <span class="time-text">{formatTime(m.time)}</span>
                  </td>
                  <td>{m.venue}</td>
                  <td class="rsvp-count">
                    <span class:list={[{ full: !isCanceled && rsvpCounts[m.id] >= m.capacity }]}>
                      {rsvpCounts[m.id]} / {m.capacity}
                    </span>
                  </td>
                  <td>
                    <div class="action-btns">
                      <a href={`/dashboard/gatherings/${m.id}/attendees`} class="btn btn-ghost btn-sm">
                        Attendees
                      </a>
                      {!isCanceled && (
                        <a href={`/dashboard/gatherings/${m.id}/edit`} class="btn btn-ghost btn-sm">
                          Edit
                        </a>
                      )}
                      <button
                        type="button"
                        class:list={["btn btn-sm", isCanceled ? "btn-ghost" : "btn-ghost btn-cancel-meetup"]}
                        data-dialog={`dialog-${m.id}`}
                      >
                        {isCanceled ? "Restore" : "Cancel"}
                      </button>
                    </div>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    )
  }

  {meetups.map((m) => {
    const isCanceled = m.status === "canceled";
    return (
      <dialog id={`dialog-${m.id}`} class="confirm-dialog">
        <div class="dialog-inner">
          <h3>{isCanceled ? "Restore this gathering?" : "Cancel this gathering?"}</h3>
          <p>
            {isCanceled
              ? <><strong>{m.title}</strong> will be marked as active again and RSVPs will re-open.</>
              : <><strong>{m.title}</strong> will be marked as cancelled. The RSVP link will show it as cancelled. You can restore it later.</>
            }
          </p>
          <div class="dialog-actions">
            <form method="POST" action={`/api/gatherings/${m.id}/cancel`}>
              <button type="submit" class:list={["btn", isCanceled ? "btn-primary" : "btn-danger"]}>
                {isCanceled ? "Yes, restore it" : "Yes, cancel it"}
              </button>
            </form>
            <button type="button" class="btn btn-ghost btn-close" data-dialog={`dialog-${m.id}`}>
              Keep as is
            </button>
          </div>
        </div>
      </dialog>
    );
  })}
</DashboardLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>("button[data-dialog]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const dialog = document.getElementById(btn.dataset.dialog!) as HTMLDialogElement | null;
      dialog?.showModal();
    });
  });

  document.querySelectorAll<HTMLButtonElement>(".btn-close[data-dialog]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const dialog = document.getElementById(btn.dataset.dialog!) as HTMLDialogElement | null;
      dialog?.close();
    });
  });

  document.querySelectorAll<HTMLDialogElement>(".confirm-dialog").forEach((dialog) => {
    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) dialog.close();
    });
  });
</script>

<style>
  .page-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .page-header h1 {
    font-size: var(--size-3xl);
  }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    background: var(--color-surface);
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-xl);
  }

  .empty-icon {
    font-size: 3.5rem;
    color: var(--color-primary);
    opacity: 0.3;
    margin-bottom: 1rem;
  }

  .empty-state h2 {
    margin-bottom: 0.5rem;
  }

  .empty-state p {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    max-width: none;
  }

  .meetups-table-wrap {
    overflow-x: auto;
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .meetups-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--size-sm);
  }

  .meetups-table th {
    background: var(--color-surface-warm);
    padding: 0.75rem 1rem;
    text-align: left;
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    border-bottom: 2px solid var(--color-border);
    white-space: nowrap;
  }

  .meetups-table td {
    padding: 0.875rem 1rem;
    border-bottom: 1px solid var(--color-border);
    vertical-align: middle;
  }

  .meetups-table tr:last-child td {
    border-bottom: none;
  }

  .meetups-table tr.past td {
    opacity: 0.6;
  }

  .meetups-table tr.canceled td {
    opacity: 0.7;
  }

  .meetup-title {
    font-weight: 700;
    color: var(--color-text);
    margin-right: 0.5rem;
  }

  .badge-canceled {
    display: inline-block;
    background: #fee2e2;
    color: #991b1b;
    padding: 0.125rem 0.5rem;
    border-radius: var(--radius-full);
    font-size: var(--size-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .btn-cancel-meetup {
    color: #991b1b;
    border-color: #fecaca;
  }

  .btn-cancel-meetup:hover {
    background: #fee2e2;
    border-color: #fca5a5;
  }

  .badge-past {
    background: #f3f4f6;
    color: #6b7280;
    padding: 0.125rem 0.5rem;
    border-radius: var(--radius-full);
    font-size: var(--size-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .nowrap {
    white-space: nowrap;
  }

  .time-text {
    color: var(--color-text-muted);
    font-size: var(--size-xs);
  }

  .rsvp-count span.full {
    color: #991b1b;
    font-weight: 700;
  }

  .action-btns {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  /* Dialog */
  .confirm-dialog {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 0;
    max-width: 420px;
    width: calc(100% - 2rem);
    box-shadow: var(--shadow-lg);
    background: var(--color-surface);
    margin: 0;
  }

  .confirm-dialog::backdrop {
    background: rgba(44, 24, 16, 0.45);
    backdrop-filter: blur(2px);
  }

  .dialog-inner {
    padding: 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .confirm-dialog h3 {
    font-size: var(--size-xl);
    margin: 0;
  }

  .confirm-dialog p {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    max-width: 34ch;
    margin: 0;
  }

  .dialog-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .dialog-actions form {
    display: contents;
  }
</style>
