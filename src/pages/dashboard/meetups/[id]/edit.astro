---
import DashboardLayout from "../../../../layouts/DashboardLayout.astro";
import { db, Groups, Meetups } from "astro:db";
import { eq, and } from "astro:db";

if (!Astro.locals.user) return Astro.redirect("/auth/login");
const user = Astro.locals.user;
const { id } = Astro.params;

if (!id) return Astro.redirect("/dashboard/meetups");

const [group] = user.groupId
  ? await db.select().from(Groups).where(eq(Groups.id, user.groupId))
  : [];

if (!group) return Astro.redirect("/dashboard");

const [meetup] = await db
  .select()
  .from(Meetups)
  .where(and(eq(Meetups.id, id), eq(Meetups.groupId, group.id)));

if (!meetup) return Astro.redirect("/dashboard/meetups");

type Result = { type: "success" } | { type: "error"; message: string };
let result: Result | null = null;

// Initial field values from DB (formatted for HTML inputs)
let vals = {
  title: meetup.title,
  description: meetup.description,
  date: meetup.date.toISOString().split("T")[0],
  time: meetup.time,
  venue: meetup.venue,
  address: meetup.address ?? "",
  capacity: String(meetup.capacity),
};

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();

  vals = {
    title: form.get("title")?.toString().trim() ?? "",
    description: form.get("description")?.toString().trim() ?? "",
    date: form.get("date")?.toString() ?? "",
    time: form.get("time")?.toString() ?? "",
    venue: form.get("venue")?.toString().trim() ?? "",
    address: form.get("address")?.toString().trim() ?? "",
    capacity: form.get("capacity")?.toString() ?? "",
  };

  const cap = Number(vals.capacity);
  const meetupDate = new Date(vals.date);

  if (!vals.title || !vals.description || !vals.date || !vals.time || !vals.venue || !vals.capacity) {
    result = { type: "error", message: "All required fields must be filled in." };
  } else if (vals.description.length < 20) {
    result = { type: "error", message: "Description must be at least 20 characters." };
  } else if (isNaN(meetupDate.getTime())) {
    result = { type: "error", message: "Invalid date." };
  } else if (!Number.isInteger(cap) || cap < 1 || cap > 500) {
    result = { type: "error", message: "Capacity must be between 1 and 500." };
  } else {
    await db
      .update(Meetups)
      .set({
        title: vals.title,
        description: vals.description,
        date: meetupDate,
        time: vals.time,
        venue: vals.venue,
        address: vals.address || null,
        capacity: cap,
      })
      .where(eq(Meetups.id, id));

    result = { type: "success" };
  }
}
---

<DashboardLayout title="Edit Meetup">
  <div class="page-header">
    <a href="/dashboard/meetups" class="back-link">← Back to meetups</a>
    <h1>Edit meetup</h1>
  </div>

  <div class="form-wrap">
    {result?.type === "success" && (
      <div class="alert alert-success" role="status">
        Meetup updated successfully! <a href="/dashboard/meetups">Back to meetups</a>
      </div>
    )}

    <form method="POST" class="meetup-form">
      {result?.type === "error" && (
        <div class="alert alert-error" role="alert">{result.message}</div>
      )}

      <div class="form-group">
        <label for="title">Meetup title *</label>
        <input id="title" name="title" type="text" value={vals.title} placeholder="Spring Social Gathering" required maxlength="100" />
      </div>

      <div class="form-group">
        <label for="description">Description *</label>
        <textarea id="description" name="description" rows="5" placeholder="What will you do? What's the vibe? Who should come?" required minlength="20" maxlength="2000">{vals.description}</textarea>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="date">Date *</label>
          <input id="date" name="date" type="date" value={vals.date} required />
        </div>
        <div class="form-group">
          <label for="time">Time *</label>
          <input id="time" name="time" type="time" value={vals.time} required />
        </div>
      </div>

      <div class="form-group">
        <label for="venue">Venue name *</label>
        <input id="venue" name="venue" type="text" value={vals.venue} placeholder="The Interval at Long Now" required />
      </div>

      <div class="form-group">
        <label for="address">Address</label>
        <input id="address" name="address" type="text" value={vals.address} placeholder="2 Marina Blvd, San Francisco, CA 94123" />
      </div>

      <div class="form-group">
        <label for="capacity">Capacity *</label>
        <input id="capacity" name="capacity" type="number" value={vals.capacity} min="1" max="500" required />
        <span class="form-hint">How many people can attend?</span>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save changes →</button>
        <a href="/dashboard/meetups" class="btn btn-ghost">Cancel</a>
      </div>
    </form>
  </div>
</DashboardLayout>

<style>
  .page-header {
    margin-bottom: 1.75rem;
  }

  .back-link {
    font-size: var(--size-sm);
    font-weight: 600;
    text-decoration: none;
    color: var(--color-text-muted);
    display: block;
    margin-bottom: 0.75rem;
  }

  .back-link:hover {
    color: var(--color-primary);
  }

  .page-header h1 {
    font-size: var(--size-3xl);
  }

  .form-wrap {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-wrap .meetup-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    max-width: 600px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-actions {
    display: flex;
    gap: 0.875rem;
    align-items: center;
  }

  @media (max-width: 480px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
