---
import DashboardLayout from "../../../../layouts/DashboardLayout.astro";
import { db, Groups, Meetups, RSVPs } from "astro:db";
import { eq, and, asc } from "astro:db";
import { formatDate, formatTime } from "../../../../lib/utils";

if (!Astro.locals.user) return Astro.redirect("/auth/login");
const user = Astro.locals.user;
const { id } = Astro.params;

if (!id) return Astro.redirect("/dashboard/meetups");

const [group] = user.groupId
  ? await db.select().from(Groups).where(eq(Groups.id, user.groupId))
  : [];

if (!group) return Astro.redirect("/dashboard");

const [meetup] = await db
  .select()
  .from(Meetups)
  .where(and(eq(Meetups.id, id), eq(Meetups.groupId, group.id)));

if (!meetup) return Astro.redirect("/dashboard/meetups");

const attendees = await db
  .select()
  .from(RSVPs)
  .where(eq(RSVPs.meetupId, id))
  .orderBy(asc(RSVPs.createdAt));

const justRemoved = Astro.url.searchParams.get("removed") === "1";
---

<DashboardLayout title={`Attendees — ${meetup.title}`}>
  <div class="page-header">
    <a href="/dashboard/meetups" class="back-link">← Back to meetups</a>
    <div class="header-row">
      <div>
        <h1>{meetup.title}</h1>
        <p class="meetup-meta">
          📅 {formatDate(meetup.date)} at {formatTime(meetup.time)} &bull; 📍 {meetup.venue}
        </p>
      </div>
      {attendees.length > 0 && (
        <a
          href={`/api/meetups/${id}/attendees.csv`}
          download
          class="btn btn-ghost btn-sm"
          title="Download attendee list as CSV"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Export CSV
        </a>
      )}
    </div>
  </div>

  {justRemoved && (
    <div class="alert alert-success" role="status">
      Attendee removed from the list.
    </div>
  )}

  <div class="attendee-stats">
    <div class="stat">
      <span class="stat-num">{attendees.length}</span>
      <span class="stat-label">RSVPs</span>
    </div>
    <div class="stat">
      <span class="stat-num">{meetup.capacity}</span>
      <span class="stat-label">Capacity</span>
    </div>
    <div class="stat">
      <span class="stat-num">{Math.max(0, meetup.capacity - attendees.length)}</span>
      <span class="stat-label">Spots left</span>
    </div>
  </div>

  {
    attendees.length === 0 ? (
      <div class="empty-state">
        <p>No RSVPs yet. Share the meetup link to start getting sign-ups!</p>
        <div class="share-link">
          <code>{`/meetups/${meetup.id}/rsvp`}</code>
        </div>
      </div>
    ) : (
      <div class="attendees-table-wrap">
        <table class="attendees-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Name</th>
              <th>Email</th>
              <th>Job Title</th>
              <th>Company</th>
              <th>RSVP'd</th>
              <th><span class="sr-only">Actions</span></th>
            </tr>
          </thead>
          <tbody>
            {attendees.map((a, i) => (
              <tr>
                <td class="row-num">{i + 1}</td>
                <td class="attendee-name">{a.name}</td>
                <td>
                  <a href={`mailto:${a.email}`}>{a.email}</a>
                </td>
                <td>{a.jobTitle}</td>
                <td>{a.company}</td>
                <td class="rsvp-date">
                  {new Intl.DateTimeFormat("en-US", {
                    month: "short",
                    day: "numeric",
                    year: "numeric",
                  }).format(a.createdAt)}
                </td>
                <td class="action-cell">
                  <button
                    type="button"
                    class="btn-remove"
                    data-dialog={`dialog-${a.id}`}
                    aria-label={`Remove ${a.name}`}
                  >
                    Remove
                  </button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )
  }

  <!-- Confirmation dialogs, one per attendee -->
  {attendees.map((a) => (
    <dialog id={`dialog-${a.id}`} class="confirm-dialog">
      <div class="dialog-inner">
        <div class="dialog-icon" aria-hidden="true">⚠️</div>
        <h3>Remove attendee?</h3>
        <p>
          This will remove <strong>{a.name}</strong> ({a.email}) from the attendee
          list for <strong>{meetup.title}</strong>. This cannot be undone.
        </p>
        <div class="dialog-actions">
          <form method="POST" action={`/api/rsvp/${a.id}/delete`}>
            <button type="submit" class="btn btn-danger">Yes, remove them</button>
          </form>
          <button type="button" class="btn btn-ghost btn-cancel" data-dialog={`dialog-${a.id}`}>
            Cancel
          </button>
        </div>
      </div>
    </dialog>
  ))}
</DashboardLayout>

<script>
  // Open dialog
  document.querySelectorAll<HTMLButtonElement>("button[data-dialog]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const dialog = document.getElementById(btn.dataset.dialog!) as HTMLDialogElement | null;
      dialog?.showModal();
    });
  });

  // Close on Cancel button
  document.querySelectorAll<HTMLButtonElement>(".btn-cancel[data-dialog]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const dialog = document.getElementById(btn.dataset.dialog!) as HTMLDialogElement | null;
      dialog?.close();
    });
  });

  // Close on backdrop click
  document.querySelectorAll<HTMLDialogElement>(".confirm-dialog").forEach((dialog) => {
    dialog.addEventListener("click", (e) => {
      if (e.target === dialog) dialog.close();
    });
  });
</script>

<style>
  .page-header {
    margin-bottom: 1.75rem;
  }

  .back-link {
    font-size: var(--size-sm);
    font-weight: 600;
    text-decoration: none;
    color: var(--color-text-muted);
    display: block;
    margin-bottom: 0.75rem;
  }

  .back-link:hover {
    color: var(--color-primary);
  }

  .header-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .page-header h1 {
    font-size: var(--size-2xl);
    margin-bottom: 0.25rem;
  }

  .meetup-meta {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    max-width: none;
  }

  .alert {
    margin-bottom: 1.25rem;
  }

  .attendee-stats {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .stat {
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
    text-align: center;
    min-width: 80px;
  }

  .stat-num {
    display: block;
    font-family: var(--font-display);
    font-size: var(--size-3xl);
    color: var(--color-primary);
    line-height: 1;
  }

  .stat-label {
    font-size: var(--size-xs);
    color: var(--color-text-muted);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .empty-state {
    text-align: center;
    padding: 3rem 2rem;
    background: var(--color-surface);
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-lg);
  }

  .empty-state p {
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    max-width: none;
  }

  .share-link {
    background: var(--color-surface-warm);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.625rem 1rem;
    display: inline-block;
  }

  .share-link code {
    font-size: var(--size-sm);
    color: var(--color-primary);
  }

  .attendees-table-wrap {
    overflow-x: auto;
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .attendees-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--size-sm);
  }

  .attendees-table th {
    background: var(--color-surface-warm);
    padding: 0.75rem 1rem;
    text-align: left;
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    border-bottom: 2px solid var(--color-border);
    white-space: nowrap;
  }

  .attendees-table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border);
    vertical-align: middle;
  }

  .attendees-table tr:last-child td {
    border-bottom: none;
  }

  .row-num {
    color: var(--color-text-muted);
    font-size: var(--size-xs);
    font-weight: 700;
  }

  .attendee-name {
    font-weight: 700;
  }

  .rsvp-date {
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .action-cell {
    text-align: right;
  }

  .btn-remove {
    background: none;
    border: none;
    padding: 0.25rem 0.5rem;
    font-size: var(--size-xs);
    font-weight: 700;
    color: var(--color-text-muted);
    cursor: pointer;
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: color var(--transition), text-decoration-color var(--transition);
    white-space: nowrap;
    font-family: inherit;
  }

  .btn-remove:hover {
    color: #c0392b;
    text-decoration-color: #c0392b;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Dialog ── */
  .confirm-dialog {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 0;
    max-width: 420px;
    width: calc(100% - 2rem);
    box-shadow: var(--shadow-lg);
    background: var(--color-surface);
    margin: 0;
  }

  .confirm-dialog::backdrop {
    background: rgba(44, 24, 16, 0.45);
    backdrop-filter: blur(2px);
  }

  .dialog-inner {
    padding: 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .dialog-icon {
    font-size: 2.5rem;
    line-height: 1;
  }

  .confirm-dialog h3 {
    font-size: var(--size-xl);
    margin: 0;
  }

  .confirm-dialog p {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    max-width: 32ch;
    margin: 0;
  }

  .dialog-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .dialog-actions form {
    display: contents;
  }
</style>
