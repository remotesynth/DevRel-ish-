---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
import { db, Groups, Meetups, RSVPs, count, eq, desc } from "astro:db";
import { formatDate, formatTime } from "../../../lib/utils";

if (!Astro.locals.user) return Astro.redirect("/auth/login");
const user = Astro.locals.user;

const [group] = user.groupId
  ? await db.select().from(Groups).where(eq(Groups.id, user.groupId))
  : [];

if (!group) return Astro.redirect("/dashboard");

const meetups = await db
  .select()
  .from(Meetups)
  .where(eq(Meetups.groupId, group.id))
  .orderBy(desc(Meetups.date));

const rsvpCounts: Record<string, number> = {};
for (const m of meetups) {
  const [r] = await db.select({ val: count() }).from(RSVPs).where(eq(RSVPs.meetupId, m.id));
  rsvpCounts[m.id] = r?.val ?? 0;
}

const today = new Date();
today.setHours(0, 0, 0, 0);
---

<DashboardLayout title="Meetups">
  <div class="page-header">
    <h1>Meetups</h1>
    <a href="/dashboard/meetups/new" class="btn btn-primary">+ New meetup</a>
  </div>

  {
    meetups.length === 0 ? (
      <div class="empty-state">
        <div class="empty-icon" aria-hidden="true">✦</div>
        <h2>No meetups yet</h2>
        <p>Schedule your first meetup and start collecting RSVPs!</p>
        <a href="/dashboard/meetups/new" class="btn btn-primary">
          Create your first meetup →
        </a>
      </div>
    ) : (
      <div class="meetups-table-wrap">
        <table class="meetups-table">
          <thead>
            <tr>
              <th>Meetup</th>
              <th>Date &amp; Time</th>
              <th>Venue</th>
              <th>RSVPs</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {meetups.map((m) => {
              const isPast = m.date < today;
              return (
                <tr class:list={[{ past: isPast }]}>
                  <td>
                    <span class="meetup-title">{m.title}</span>
                    {isPast && <span class="badge badge-past">Past</span>}
                  </td>
                  <td class="nowrap">
                    {formatDate(m.date)}<br />
                    <span class="time-text">{formatTime(m.time)}</span>
                  </td>
                  <td>{m.venue}</td>
                  <td class="rsvp-count">
                    <span class:list={[{ full: rsvpCounts[m.id] >= m.capacity }]}>
                      {rsvpCounts[m.id]} / {m.capacity}
                    </span>
                  </td>
                  <td>
                    <div class="action-btns">
                      <a href={`/dashboard/meetups/${m.id}/attendees`} class="btn btn-ghost btn-sm">
                        Attendees
                      </a>
                      <a href={`/dashboard/meetups/${m.id}/edit`} class="btn btn-ghost btn-sm">
                        Edit
                      </a>
                    </div>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    )
  }
</DashboardLayout>

<style>
  .page-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .page-header h1 {
    font-size: var(--size-3xl);
  }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    background: var(--color-surface);
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-xl);
  }

  .empty-icon {
    font-size: 3.5rem;
    color: var(--color-primary);
    opacity: 0.3;
    margin-bottom: 1rem;
  }

  .empty-state h2 {
    margin-bottom: 0.5rem;
  }

  .empty-state p {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    max-width: none;
  }

  .meetups-table-wrap {
    overflow-x: auto;
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .meetups-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--size-sm);
  }

  .meetups-table th {
    background: var(--color-surface-warm);
    padding: 0.75rem 1rem;
    text-align: left;
    font-size: var(--size-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    border-bottom: 2px solid var(--color-border);
    white-space: nowrap;
  }

  .meetups-table td {
    padding: 0.875rem 1rem;
    border-bottom: 1px solid var(--color-border);
    vertical-align: middle;
  }

  .meetups-table tr:last-child td {
    border-bottom: none;
  }

  .meetups-table tr.past td {
    opacity: 0.6;
  }

  .meetup-title {
    font-weight: 700;
    color: var(--color-text);
    margin-right: 0.5rem;
  }

  .badge-past {
    background: #f3f4f6;
    color: #6b7280;
    padding: 0.125rem 0.5rem;
    border-radius: var(--radius-full);
    font-size: var(--size-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .nowrap {
    white-space: nowrap;
  }

  .time-text {
    color: var(--color-text-muted);
    font-size: var(--size-xs);
  }

  .rsvp-count span.full {
    color: #991b1b;
    font-weight: 700;
  }

  .action-btns {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }
</style>
