---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
import { db, Groups } from "astro:db";
import { eq } from "astro:db";
import { CATEGORIES } from "../../../lib/categories";
import { groupUrl } from "../../../lib/utils";

if (!Astro.locals.user) return Astro.redirect("/auth/login");
const user = Astro.locals.user;

const [group] = user.groupId
  ? await db.select().from(Groups).where(eq(Groups.id, user.groupId))
  : [];

if (!group) return Astro.redirect("/dashboard");

// Slugs that cannot be used as custom short URLs (reserved by the app's routing)
const RESERVED_SLUGS = new Set([
  "admin", "api", "auth", "dashboard", "follow", "gatherings",
  "groups", "invite", "privacy", "setup", "how-it-works",
]);

let successMsg = "";
let errorMsg = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const description = form.get("description")?.toString().trim() ?? "";
  const contactEmail = form.get("contactEmail")?.toString().trim() ?? "";
  const tagline = form.get("tagline")?.toString().trim() ?? "";
  const category = form.get("category")?.toString().trim() ?? "";
  const tags = form.get("tags")?.toString().trim() ?? "";
  const city = form.get("city")?.toString().trim() ?? "";
  const region = form.get("region")?.toString().trim() ?? "";
  const country = form.get("country")?.toString().trim() ?? "";
  const website = form.get("website")?.toString().trim() ?? "";
  const blueskyHandle = form.get("blueskyHandle")?.toString().trim() ?? "";
  const linkedinUrl = form.get("linkedinUrl")?.toString().trim() ?? "";
  const customSlugRaw = form.get("customSlug")?.toString().trim().toLowerCase() ?? "";

  let customSlugValue: string | null = null;
  let customSlugError = "";

  if (customSlugRaw) {
    if (!/^[a-z0-9]+(?:-[a-z0-9]+)*$/.test(customSlugRaw)) {
      customSlugError = "Short URL may only contain lowercase letters, numbers, and hyphens (no leading/trailing hyphens).";
    } else if (customSlugRaw.length < 3 || customSlugRaw.length > 60) {
      customSlugError = "Short URL must be between 3 and 60 characters.";
    } else if (RESERVED_SLUGS.has(customSlugRaw)) {
      customSlugError = `"${customSlugRaw}" is reserved and cannot be used as a short URL.`;
    } else {
      // Check uniqueness (ignore current group's own value)
      const [conflict] = await db
        .select({ id: Groups.id })
        .from(Groups)
        .where(eq(Groups.customSlug, customSlugRaw));
      if (conflict && conflict.id !== group.id) {
        customSlugError = "That short URL is already taken by another group.";
      } else {
        customSlugValue = customSlugRaw;
      }
    }
  }

  if (!description || !contactEmail) {
    errorMsg = "Description and contact email are required.";
  } else if (category && !CATEGORIES.find(c => c.slug === category)) {
    errorMsg = "Please select a valid community category.";
  } else if (description.length < 50) {
    errorMsg = "Description must be at least 50 characters.";
  } else if (customSlugError) {
    errorMsg = customSlugError;
  } else {
    await db
      .update(Groups)
      .set({
        description,
        contactEmail,
        tagline: tagline || null,
        category: category || null,
        tags: tags || null,
        city: city || null,
        region: region || null,
        country: country || null,
        website: website || null,
        blueskyHandle: blueskyHandle || null,
        linkedinUrl: linkedinUrl || null,
        customSlug: customSlugValue,
      })
      .where(eq(Groups.id, group.id));
    successMsg = "Group details updated!";
    const [updated] = await db.select().from(Groups).where(eq(Groups.id, group.id));
    if (updated) Object.assign(group, updated);
  }
}
---

<DashboardLayout title="My Group">
  <div class="page-header">
    <h1>My Group</h1>
    <a href={groupUrl(group)} class="btn btn-ghost btn-sm" target="_blank" rel="noopener">
      View public page ↗
    </a>
  </div>

  {successMsg && <div class="alert alert-success">{successMsg}</div>}
  {errorMsg && <div class="alert alert-error">{errorMsg}</div>}

  <form method="POST" class="group-edit-form">

    <div class="form-card">
      <h3>Identity</h3>

      <div class="form-group">
        <label>Group name</label>
        <input type="text" value={group.name} disabled class="input-disabled" />
        <span class="form-hint">Contact support to change your group name.</span>
      </div>

      <div class="form-group">
        <label for="tagline">Tagline</label>
        <input
          id="tagline" name="tagline" type="text"
          value={group.tagline ?? ""}
          placeholder="Connecting DevRel folks at major tech events"
          maxlength="120"
        />
        <span class="form-hint">One short sentence shown on your group card.</span>
      </div>

      <div class="form-group">
        <label for="category">Community category</label>
        <select id="category" name="category">
          <option value="" disabled selected={!group.category}>Select a category…</option>
          {CATEGORIES.map(c => (
            <option value={c.slug} selected={group.category === c.slug}>{c.label}</option>
          ))}
        </select>
        <span class="form-hint">The primary category for your community.</span>
      </div>

      <div class="form-group">
        <label for="tags">Tags</label>
        <input
          id="tags" name="tags" type="text"
          value={group.tags ?? ""}
          placeholder="enterprise, open-source, api-first"
        />
        <span class="form-hint">Optional subtopics, comma-separated. Helps people find your group.</span>
      </div>

      <div class="form-group">
        <label for="description">Description *</label>
        <textarea id="description" name="description" required minlength="50" maxlength="1000" rows={6}>{group.description}</textarea>
        <span class="form-hint">Markdown supported: **bold**, *italic*, # headings, - lists, [links](url).</span>
      </div>

      <div class="form-group">
        <label for="contactEmail">Contact email *</label>
        <input id="contactEmail" name="contactEmail" type="email" value={group.contactEmail} required />
      </div>
    </div>

    <div class="form-card">
      <h3>Short URL <span class="optional-label">(optional)</span></h3>
      <p class="card-desc">
        Give your group a memorable link at <strong>devrelish.tech/your-slug</strong> — shorter and easier to share than the full URL.
      </p>

      <div class="form-group">
        <label for="customSlug">Custom short URL</label>
        <div class="slug-input-wrap">
          <span class="slug-prefix">devrelish.tech/</span>
          <input
            id="customSlug" name="customSlug" type="text"
            value={group.customSlug ?? ""}
            placeholder="sf-user-group"
            pattern="[a-z0-9]+(?:-[a-z0-9]+)*"
            minlength="3"
            maxlength="60"
          />
        </div>
        <span class="form-hint">
          Lowercase letters, numbers, and hyphens only. Leave blank to use the default URL
          (<code>/groups/{group.slug}</code>).
          {group.customSlug && (
            <> Your current short URL: <a href={`/${group.customSlug}`} target="_blank" rel="noopener"><strong>devrelish.tech/{group.customSlug}</strong></a></>
          )}
        </span>
      </div>
    </div>

    <div class="form-card">
      <h3>Location <span class="optional-label">(optional)</span></h3>
      <p class="card-desc">Leave blank if your group is event-based or distributed.</p>

      <div class="form-row">
        <div class="form-group">
          <label for="city">City</label>
          <input id="city" name="city" type="text" value={group.city ?? ""} placeholder="San Francisco" />
        </div>
        <div class="form-group">
          <label for="region">State / Province</label>
          <input id="region" name="region" type="text" value={group.region ?? ""} placeholder="CA" />
        </div>
      </div>

      <div class="form-group">
        <label for="country">Country</label>
        <input id="country" name="country" type="text" value={group.country ?? ""} placeholder="USA" />
      </div>
    </div>

    <div class="form-card">
      <h3>Online presence <span class="optional-label">(optional)</span></h3>

      <div class="form-group">
        <label for="website">Website</label>
        <input id="website" name="website" type="url" value={group.website ?? ""} placeholder="https://yourgroup.com" />
      </div>

      <div class="form-group">
        <label for="blueskyHandle">Bluesky handle</label>
        <input id="blueskyHandle" name="blueskyHandle" type="text" value={group.blueskyHandle ?? ""} placeholder="yourgroup.bsky.social" />
      </div>

      <div class="form-group">
        <label for="linkedinUrl">LinkedIn URL</label>
        <input id="linkedinUrl" name="linkedinUrl" type="url" value={group.linkedinUrl ?? ""} placeholder="https://linkedin.com/company/yourgroup" />
      </div>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Save changes →</button>
    </div>
  </form>
</DashboardLayout>

<style>
  .page-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .page-header h1 { font-size: var(--size-3xl); }

  .alert { margin-bottom: 1.25rem; }

  .group-edit-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-card {
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-card h3 {
    font-size: var(--size-lg);
    padding-bottom: 0.625rem;
    border-bottom: 1px dashed var(--color-border);
  }

  .optional-label {
    font-size: var(--size-sm);
    font-weight: 400;
    color: var(--color-text-light);
    font-family: var(--font-body);
  }

  .card-desc {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    margin: 0;
    max-width: none;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .input-disabled {
    background: var(--color-surface-warm) !important;
    color: var(--color-text-muted) !important;
    cursor: not-allowed;
  }

  .slug-input-wrap {
    display: flex;
    align-items: center;
    border: 2px solid var(--color-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--color-surface);
    transition: border-color var(--transition);
  }

  .slug-input-wrap:focus-within {
    border-color: var(--color-primary);
  }

  .slug-prefix {
    padding: 0.5rem 0.75rem;
    background: var(--color-surface-warm);
    border-right: 2px solid var(--color-border);
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .slug-input-wrap input {
    border: none !important;
    border-radius: 0 !important;
    flex: 1;
    min-width: 0;
    outline: none !important;
    box-shadow: none !important;
  }

  .form-actions { padding-top: 0.5rem; }

  @media (max-width: 560px) {
    .form-row { grid-template-columns: 1fr; }
  }
</style>
