---
import BaseLayout from '../layouts/BaseLayout.astro';
import GroupCard from '../components/groups/GroupCard.astro';
import GatheringCardCompact from '../components/meetups/GatheringCardCompact.astro';
import {
  db,
  Groups,
  Meetups,
  RSVPs,
  count,
  eq,
  and,
  gte,
  asc,
  desc,
  inArray,
} from 'astro:db';

const today = new Date();
today.setHours(0, 0, 0, 0);

// Approved groups lookup
const approvedGroups = await db
  .select()
  .from(Groups)
  .where(eq(Groups.status, 'approved'));
const groupMap = new Map(approvedGroups.map((g) => [g.id, g]));
const approvedGroupIds = new Set(approvedGroups.map((g) => g.id));

// 6 nearest upcoming gatherings (2 rows of 3)
const allUpcoming = await db
  .select()
  .from(Meetups)
  .where(and(eq(Meetups.status, 'active'), gte(Meetups.date, today)))
  .orderBy(asc(Meetups.date))
  .limit(20);

const upcomingGatherings = allUpcoming
  .filter((m) => approvedGroupIds.has(m.groupId))
  .slice(0, 6);

const meetupIds = upcomingGatherings.map((m) => m.id);
const rsvpRows = meetupIds.length
  ? await db.select({ meetupId: RSVPs.meetupId, val: count() })
      .from(RSVPs)
      .where(inArray(RSVPs.meetupId, meetupIds))
      .groupBy(RSVPs.meetupId)
  : [];
const rsvpCounts: Record<string, number> = Object.fromEntries(rsvpRows.map((r) => [r.meetupId, r.val]));

// Featured groups
const featuredGroups = await db
  .select()
  .from(Groups)
  .where(eq(Groups.status, 'approved'))
  .orderBy(desc(Groups.createdAt))
  .limit(3);

const featuredGroupIds = featuredGroups.map((g) => g.id);
const upcomingRows = featuredGroupIds.length
  ? await db.select({ groupId: Meetups.groupId, val: count() })
      .from(Meetups)
      .where(and(inArray(Meetups.groupId, featuredGroupIds), gte(Meetups.date, today)))
      .groupBy(Meetups.groupId)
  : [];
const upcomingCounts: Record<string, number> = Object.fromEntries(upcomingRows.map((r) => [r.groupId, r.val]));
---

<BaseLayout
  title="Real Connections for Developer and Technical Community Folks"
>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content">
        <div class="hero-eyebrow">✦ IRL gatherings for niche communities</div>
        <h1 class="hero-headline">
          Find your<br />
          <span class="headline-accent">community.</span>
        </h1>
        <p class="hero-lead">
          Technical communities are spread across a big planet. DevRel(ish)
          brings them together for real-life gatherings — at conferences, in
          cities, and wherever your people happen to be.
        </p>
        <div class="hero-actions">
          <a href="/gatherings" class="btn btn-primary btn-lg"
            >Find a gathering →</a
          >
          <a href="/groups/register" class="btn btn-ghost btn-lg"
            >Start a group</a
          >
        </div>
      </div>
      <div class="hero-illustration" aria-hidden="true">
        <div class="blob blob-1">◈</div>
        <div class="blob blob-2">✦</div>
        <div class="blob blob-3">◎</div>
        <div class="blob blob-4">◇</div>
        <div class="blob-center">
          <div class="people-blob">
            <span>👋</span>
            <span>🤝</span>
            <span>🌟</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why section -->
  <section class="why-section">
    <div class="container">
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">🌐</div>
          <h3>Real people, real gatherings</h3>
          <p>
            Online communities are great. But there's nothing like meeting your
            people in person. DevRel(ish) exists to make those moments happen.
          </p>
        </div>
        <div class="why-card">
          <div class="why-icon">💬</div>
          <h3>Find your niche</h3>
          <p>
            Generic tech meetups are fine. We're for something more specific —
            communities with a shared identity, vocabulary, and set of problems.
          </p>
        </div>
        <div class="why-card">
          <div class="why-icon">🔋</div>
          <h3>No agendas, no sponsors</h3>
          <p>
            No pitch decks, no badge scans, no hidden sales funnels. Just good
            people, good conversation, and the kind of energy you can't get on a
            call.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Upcoming gatherings -->
  <section class="gatherings-section">
    <div class="container">
      <div class="section-header">
        <h2>Upcoming gatherings</h2>
        <a href="/gatherings" class="btn btn-ghost">See all →</a>
      </div>

      {
        upcomingGatherings.length === 0 ? (
          <div class="empty-state">
            <p>
              No gatherings scheduled yet — check back soon, or{' '}
              <a href="/groups/register">start a group</a>.
            </p>
          </div>
        ) : (
          <div class="gatherings-grid">
            {upcomingGatherings.map((m) => {
              const group = groupMap.get(m.groupId)!;
              return (
                <GatheringCardCompact
                  id={m.id}
                  title={m.title}
                  date={m.date}
                  time={m.time}
                  venue={m.venue}
                  address={m.address}
                  city={m.city}
                  country={m.country}
                  eventContext={m.eventContext}
                  capacity={m.capacity}
                  rsvpCount={rsvpCounts[m.id] ?? 0}
                  groupName={group.name}
                />
              );
            })}
          </div>
        )
      }
    </div>
  </section>

  <!-- Groups -->
  {
    featuredGroups.length > 0 && (
      <section class="groups-section">
        <div class="container">
          <div class="section-header">
            <h2>Find a group near you</h2>
            <a href="/groups" class="btn btn-ghost">
              See all groups →
            </a>
          </div>
          <div class="groups-grid">
            {featuredGroups.map((g) => (
              <GroupCard
                id={g.id}
                name={g.name}
                slug={g.slug}
                customSlug={g.customSlug}
                city={g.city}
                region={g.region}
                country={g.country}
                tagline={g.tagline}
                category={g.category}
                tags={g.tags}
                description={g.description}
                upcomingCount={upcomingCounts[g.id]}
              />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-card">
        <div class="cta-decoration" aria-hidden="true">◈ ✦ ◎</div>
        <h2>Want to organize gatherings?</h2>
        <p>
          Whether you're based in a city or just travel to a lot of conferences,
          you can start a group for your community. Fill out a quick form and
          we'll get you set up.
        </p>
        <a href="/groups/register" class="btn btn-secondary btn-lg"
          >Start a group →</a
        >
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    padding: clamp(3rem, 8vw, 6rem) 0 clamp(2rem, 6vw, 4rem);
    background: linear-gradient(
      135deg,
      var(--color-bg) 0%,
      var(--color-surface-warm) 50%,
      var(--color-bg) 100%
    );
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-eyebrow {
    display: inline-block;
    font-size: var(--size-sm);
    font-weight: 700;
    color: var(--color-primary);
    background: rgba(232, 112, 74, 0.1);
    padding: 0.25rem 0.875rem;
    border-radius: var(--radius-full);
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
  }

  .hero-headline {
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .headline-accent {
    color: var(--color-primary);
  }

  .hero-lead {
    font-size: var(--size-lg);
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 52ch;
  }

  .hero-actions {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
  }

  .hero-illustration {
    position: relative;
    height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .blob {
    position: absolute;
    font-size: 2rem;
    color: var(--color-primary);
    opacity: 0.15;
    animation: float 6s ease-in-out infinite;
  }

  .blob-1 {
    top: 10%;
    left: 10%;
    font-size: 3rem;
    animation-delay: 0s;
    color: var(--color-primary);
  }
  .blob-2 {
    top: 20%;
    right: 15%;
    font-size: 1.5rem;
    animation-delay: 1s;
    color: var(--color-secondary);
  }
  .blob-3 {
    bottom: 15%;
    left: 20%;
    font-size: 2rem;
    animation-delay: 2s;
    color: var(--color-accent);
  }
  .blob-4 {
    bottom: 25%;
    right: 10%;
    font-size: 2.5rem;
    animation-delay: 0.5s;
    color: var(--color-sky);
  }

  .blob-center {
    position: relative;
    z-index: 1;
    background: var(--color-surface);
    border: 3px solid var(--color-border);
    border-radius: 50%;
    width: 160px;
    height: 160px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-lg);
  }

  .people-blob {
    display: flex;
    gap: 0.25rem;
    font-size: 2.5rem;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0) rotate(0deg);
    }
    50% {
      transform: translateY(-12px) rotate(5deg);
    }
  }

  /* ── Why ── */
  .why-section {
    padding: clamp(2.5rem, 6vw, 4rem) 0;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .why-card {
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    transition:
      transform var(--transition),
      box-shadow var(--transition);
  }

  .why-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  .why-icon {
    font-size: 2.5rem;
    margin-bottom: 0.875rem;
    line-height: 1;
  }
  .why-card h3 {
    font-size: var(--size-xl);
    margin-bottom: 0.625rem;
  }
  .why-card p {
    color: var(--color-text-muted);
    font-size: var(--size-sm);
  }

  /* ── Gatherings ── */
  .gatherings-section {
    padding: clamp(2.5rem, 6vw, 4rem) 0;
    background: var(--color-surface-warm);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.75rem;
    flex-wrap: wrap;
  }

  .section-header h2 {
    font-size: var(--size-3xl);
  }

  .gatherings-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .empty-state {
    padding: 3rem 2rem;
    text-align: center;
    background: var(--color-surface);
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-lg);
  }

  .empty-state p {
    color: var(--color-text-muted);
    max-width: none;
  }

  /* ── Groups ── */
  .groups-section {
    padding: clamp(2.5rem, 6vw, 4rem) 0;
  }

  .groups-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* ── CTA ── */
  .cta-section {
    padding: clamp(2.5rem, 6vw, 4rem) 0;
  }

  .cta-card {
    background: var(--color-primary);
    color: white;
    border-radius: var(--radius-xl);
    padding: clamp(2rem, 5vw, 3.5rem);
    text-align: center;
    overflow: hidden;
  }

  .cta-card h2 {
    color: white;
    font-size: var(--size-3xl);
    margin-bottom: 0.875rem;
  }

  .cta-card p {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--size-lg);
    margin: 0 auto 1.75rem;
    max-width: 50ch;
  }

  .cta-decoration {
    font-size: var(--size-2xl);
    color: rgba(255, 255, 255, 0.25);
    letter-spacing: 0.5rem;
    margin-bottom: 1rem;
  }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .gatherings-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .groups-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
    .hero-illustration {
      display: none;
    }
  }

  @media (max-width: 560px) {
    .gatherings-grid {
      grid-template-columns: 1fr;
    }
    .groups-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
