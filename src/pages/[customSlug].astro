---
/**
 * Handles organizer-chosen short URLs like /sf-user-group.
 * Renders the group page directly so the short URL stays in the address bar.
 */
import GroupPage from "../components/groups/GroupPage.astro";
import { db, Groups, Meetups, RSVPs, Followers, count, eq, and, gte, asc } from "astro:db";

const { customSlug } = Astro.params;
if (!customSlug) return Astro.redirect("/groups");

const [group] = await db
  .select()
  .from(Groups)
  .where(eq(Groups.customSlug, customSlug));

if (!group || (group.status !== "approved" && group.status !== "closed")) {
  return new Response(null, { status: 404 });
}

const today = new Date();
today.setHours(0, 0, 0, 0);

const meetups = await db
  .select()
  .from(Meetups)
  .where(and(eq(Meetups.groupId, group.id), gte(Meetups.date, today)))
  .orderBy(asc(Meetups.date));

const rsvpCounts: Record<string, number> = {};
for (const meetup of meetups) {
  const [r] = await db.select({ val: count() }).from(RSVPs).where(eq(RSVPs.meetupId, meetup.id));
  rsvpCounts[meetup.id] = r?.val ?? 0;
}

const [followerResult] = await db
  .select({ val: count() })
  .from(Followers)
  .where(and(eq(Followers.groupId, group.id), eq(Followers.confirmed, true)));
const followerCount = followerResult?.val ?? 0;
---

<GroupPage group={group} meetups={meetups} rsvpCounts={rsvpCounts} followerCount={followerCount} />
