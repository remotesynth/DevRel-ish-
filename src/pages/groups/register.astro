---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { db, Groups } from "astro:db";
import { eq } from "astro:db";
import { generateId, slugify } from "../../lib/utils";

type Result =
  | { type: "success"; email: string }
  | { type: "error"; message: string };

let result: Result | null = null;

let vals = {
  name: "", tagline: "", city: "", region: "", country: "", description: "", contactEmail: "",
};

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();

  vals = {
    name:         form.get("name")?.toString().trim() ?? "",
    tagline:      form.get("tagline")?.toString().trim() ?? "",
    city:         form.get("city")?.toString().trim() ?? "",
    region:       form.get("region")?.toString().trim() ?? "",
    country:      form.get("country")?.toString().trim() ?? "",
    description:  form.get("description")?.toString().trim() ?? "",
    contactEmail: form.get("contactEmail")?.toString().trim().toLowerCase() ?? "",
  };

  const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  if (!vals.name || !vals.description || !vals.contactEmail) {
    result = { type: "error", message: "Name, description, and contact email are required." };
  } else if (vals.description.length < 50) {
    result = { type: "error", message: "Description must be at least 50 characters." };
  } else if (!emailRe.test(vals.contactEmail)) {
    result = { type: "error", message: "Please enter a valid email address." };
  } else {
    const [existing] = await db.select().from(Groups).where(eq(Groups.name, vals.name));
    if (existing) {
      result = { type: "error", message: "A group with that name already exists." };
    } else {
      let slug = slugify(vals.name);
      const [slugConflict] = await db.select().from(Groups).where(eq(Groups.slug, slug));
      if (slugConflict) slug = `${slug}-${Math.random().toString(36).slice(2, 6)}`;

      await db.insert(Groups).values({
        id: generateId(),
        name: vals.name,
        slug,
        tagline: vals.tagline || null,
        city: vals.city || null,
        region: vals.region || null,
        country: vals.country || null,
        description: vals.description,
        contactEmail: vals.contactEmail,
        status: "pending",
        createdAt: new Date(),
      });

      result = { type: "success", email: vals.contactEmail };
    }
  }
}
---

<BaseLayout
  title="Start a Group"
  description="Apply to start a DevRel(ish) group in your city. We'll review your application and get back to you soon."
>
  <section class="page-hero">
    <div class="container">
      <div class="hero-eyebrow">✦ New group application</div>
      <h1>Start a DevRel(ish) group</h1>
      <p>
        Want to organize gatherings for DevRel folks — in your city, at conferences, or wherever the community meets?
        Fill out this form and we'll get you set up.
      </p>
    </div>
  </section>

  <section class="form-section">
    <div class="container form-layout">
      <div class="form-main">
        {result?.type === "success" ? (
          <div class="success-state">
            <div class="success-icon" aria-hidden="true">✦</div>
            <h2>Application submitted!</h2>
            <p>
              Thanks for wanting to start a DevRel(ish) group! We'll review your application
              and be in touch at <strong>{result.email}</strong> shortly.
            </p>
            <p>
              In the meantime, check out the <a href="/groups">existing groups</a> to see if
              there's one near you.
            </p>
          </div>
        ) : (
          <form method="POST" class="group-form">
            {result?.type === "error" && (
              <div class="alert alert-error" role="alert">{result.message}</div>
            )}

            <div class="form-section-block">
              <h3 class="section-title">About your group</h3>

              <div class="form-group">
                <label for="name">Group name *</label>
                <input
                  id="name" name="name" type="text"
                  value={vals.name}
                  placeholder="DevRel(ish) SF, DevRel Connectors..."
                  required minlength="3" maxlength="80"
                />
                <span class="form-hint">
                  We'll turn it into a URL slug like <code>/groups/devrel-sf</code>.
                </span>
              </div>

              <div class="form-group">
                <label for="tagline">Tagline</label>
                <input
                  id="tagline" name="tagline" type="text"
                  value={vals.tagline}
                  placeholder="Connecting DevRel folks at major tech events"
                  maxlength="120"
                />
                <span class="form-hint">One short sentence that describes what your group is about.</span>
              </div>

              <div class="form-group">
                <label for="description">Description *</label>
                <textarea
                  id="description" name="description"
                  placeholder="Tell us about your group — who it's for, the vibe, what you'll do together..."
                  required minlength="50" maxlength="1000"
                  rows="5"
                >{vals.description}</textarea>
                <span class="form-hint">Markdown supported: **bold**, *italic*, # headings, - lists, [links](url).</span>
              </div>
            </div>

            <div class="form-section-block">
              <h3 class="section-title">Location <span class="optional-label">(optional)</span></h3>
              <p class="section-desc">If your group is tied to a city, fill this in. If you're event-based or distributed, leave it blank.</p>

              <div class="form-row">
                <div class="form-group">
                  <label for="city">City</label>
                  <input id="city" name="city" type="text" value={vals.city} placeholder="San Francisco" />
                </div>
                <div class="form-group">
                  <label for="region">State / Province</label>
                  <input id="region" name="region" type="text" value={vals.region} placeholder="CA" maxlength="50" />
                </div>
              </div>

              <div class="form-group">
                <label for="country">Country</label>
                <input id="country" name="country" type="text" value={vals.country} placeholder="USA" />
              </div>
            </div>

            <div class="form-section-block">
              <h3 class="section-title">Your contact info</h3>

              <div class="form-group">
                <label for="contactEmail">Email address *</label>
                <input
                  id="contactEmail" name="contactEmail" type="email"
                  value={vals.contactEmail}
                  placeholder="you@example.com"
                  required
                />
                <span class="form-hint">
                  This is how we'll reach you when your group is approved. You'll use this to sign in.
                </span>
              </div>
            </div>

            <div class="form-actions">
              <button type="submit" class="btn btn-primary btn-lg">
                Submit application →
              </button>
              <p class="form-hint">
                We review all applications within a few days. You'll hear from us either way!
              </p>
            </div>
          </form>
        )}
      </div>

      <aside class="form-sidebar">
        <div class="sidebar-card">
          <h3>What happens next</h3>
          <ol class="steps-list">
            <li>
              <span class="step-num">1</span>
              <div>
                <strong>You submit this form</strong>
                <p>Takes about 2 minutes.</p>
              </div>
            </li>
            <li>
              <span class="step-num">2</span>
              <div>
                <strong>We review your application</strong>
                <p>Usually within a few days. We'll email you either way.</p>
              </div>
            </li>
            <li>
              <span class="step-num">3</span>
              <div>
                <strong>You get access</strong>
                <p>Log in and start creating gatherings for your group!</p>
              </div>
            </li>
          </ol>
        </div>

        <div class="sidebar-card sidebar-card-warm">
          <h3>What is DevRel(ish)?</h3>
          <p>
            The "(ish)" is intentional — your group should welcome anyone doing the work of DevRel,
            regardless of their title. Developer advocates, community managers, DX engineers,
            developer content writers... all welcome.
          </p>
        </div>

        <div class="sidebar-card">
          <h3>Organizer data rules</h3>
          <p>
            By starting a group you agree to use attendee contact information only for organizing
            your DevRel(ish) events. Sharing, selling, or marketing to attendees outside of
            event-related communications is not permitted.
          </p>
          <a href="/privacy#organizer-rules" class="sidebar-link">Read the full organizer rules →</a>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 3rem 0 2rem;
    background: var(--color-surface-warm);
    border-bottom: 2px solid var(--color-border);
  }

  .hero-eyebrow {
    display: inline-block;
    font-size: var(--size-sm);
    font-weight: 700;
    color: var(--color-primary);
    background: rgba(232, 112, 74, 0.1);
    padding: 0.25rem 0.875rem;
    border-radius: var(--radius-full);
    margin-bottom: 0.75rem;
  }

  .page-hero h1 {
    margin-bottom: 0.75rem;
  }

  .page-hero p {
    font-size: var(--size-lg);
    color: var(--color-text-muted);
    max-width: 56ch;
  }

  .form-section {
    padding: 2.5rem 0 4rem;
  }

  .form-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 2.5rem;
    align-items: start;
  }

  /* Form */
  .group-form {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .form-section-block {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
  }

  .section-title {
    font-size: var(--size-lg);
    margin: 0;
    padding-bottom: 0.5rem;
    border-bottom: 1px dashed var(--color-border);
  }

  .optional-label {
    font-size: var(--size-sm);
    font-weight: 400;
    color: var(--color-text-light);
    font-family: var(--font-body);
  }

  .section-desc {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    margin: 0;
    max-width: none;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* Success */
  .success-state {
    text-align: center;
    padding: 3rem 2rem;
    background: var(--color-surface);
    border: 2px solid var(--color-accent);
    border-radius: var(--radius-lg);
  }

  .success-icon {
    font-size: 3rem;
    color: var(--color-accent);
    margin-bottom: 1rem;
    display: block;
  }

  .success-state h2 {
    margin-bottom: 0.75rem;
    color: var(--color-accent-dark);
  }

  .success-state p {
    color: var(--color-text-muted);
    margin: 0 auto 0.75rem;
    max-width: 44ch;
  }

  /* Sidebar */
  .form-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: sticky;
    top: 80px;
  }

  .sidebar-card {
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
  }

  .sidebar-card-warm {
    background: var(--color-surface-warm);
    border-color: var(--color-border-strong);
  }

  .sidebar-card h3 {
    font-size: var(--size-base);
    margin-bottom: 0.875rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px dashed var(--color-border);
  }

  .sidebar-card p {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .sidebar-link {
    font-size: var(--size-xs);
    font-weight: 700;
  }

  .steps-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .steps-list li {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .step-num {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--color-primary);
    color: white;
    font-size: var(--size-xs);
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .steps-list strong {
    display: block;
    font-size: var(--size-sm);
    margin-bottom: 0.125rem;
  }

  .steps-list p {
    font-size: var(--size-xs);
    margin: 0;
  }

  @media (max-width: 768px) {
    .form-layout {
      grid-template-columns: 1fr;
    }

    .form-sidebar {
      position: static;
    }

    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
