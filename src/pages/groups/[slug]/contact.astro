---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { db, Groups, ContactMessages, User, eq, and } from "astro:db";
import { generateId, groupUrl } from "../../../lib/utils";
import { stripMarkdown } from "../../../lib/markdown";
import { sendContactMessageAlert } from "../../../lib/email";

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/groups");

const [group] = await db
  .select()
  .from(Groups)
  .where(eq(Groups.slug, slug));

if (!group || (group.status !== "approved" && group.status !== "closed")) {
  return Astro.redirect("/groups");
}

const isGroupClosed = group.status === "closed";

type FormResult = { type: "success" } | { type: "error"; message: string };
let result: FormResult | null = null;
const descPlain = stripMarkdown(group.description);
const descSnippet = descPlain.length > 200 ? descPlain.slice(0, 200) + "…" : descPlain;

if (!isGroupClosed && Astro.request.method === "POST") {
  const form = await Astro.request.formData();

  const hp = form.get("_hp")?.toString() ?? "";
  const submittedAt = parseInt(form.get("_t")?.toString() ?? "0", 10);

  if (hp || !submittedAt || Date.now() - submittedAt < 3000) {
    result = { type: "success" };
  } else {
    const name = form.get("name")?.toString().trim() ?? "";
    const email = form.get("email")?.toString().trim().toLowerCase() ?? "";
    const message = form.get("message")?.toString().trim() ?? "";

    if (!name || !email || !message) {
      result = { type: "error", message: "All fields are required." };
    } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      result = { type: "error", message: "Please enter a valid email address." };
    } else if (message.length > 2000) {
      result = { type: "error", message: "Message must be 2000 characters or fewer." };
    } else {
      await db.insert(ContactMessages).values({
        id: generateId(),
        groupId: group.id,
        name,
        email,
        message,
        read: false,
        createdAt: new Date(),
      });

      // Notify organizers — fire-and-forget, no message body included
      const organizers = await db.select({ email: User.email, name: User.name }).from(User).where(eq(User.groupId, group.id));
      if (organizers.length > 0) {
        sendContactMessageAlert({
          organizers,
          groupName: group.name,
          dashboardUrl: `${Astro.url.origin}/dashboard/messages`,
        }).catch(e => console.error("[contact alert] email error:", e));
      }

      result = { type: "success" };
    }
  }
}
---

<BaseLayout
  title={`Contact ${group.name}`}
  description={`Send a message to the organizers of ${group.name}.`}
>
  <section class="contact-page">
    <div class="container contact-layout">
      <div class="contact-main">
        <div class="breadcrumb">
          <a href="/groups">Groups</a>
          <span aria-hidden="true">→</span>
          <a href={groupUrl(group)}>{group.name}</a>
          <span aria-hidden="true">→</span>
          <span>Contact</span>
        </div>

        {isGroupClosed ? (
          <div class="closed-state">
            <h1>Group closed</h1>
            <p><strong>{group.name}</strong> is no longer active and is not accepting messages.</p>
            <a href={groupUrl(group)} class="btn btn-ghost">← Back to {group.name}</a>
          </div>
        ) : result?.type === "success" ? (
          <div class="success-state">
            <div class="success-icon" aria-hidden="true">✉️</div>
            <h1>Message sent!</h1>
            <p>The organizers of <strong>{group.name}</strong> will be in touch via the email you provided.</p>
            <a href={groupUrl(group)} class="btn btn-ghost">← Back to {group.name}</a>
          </div>
        ) : (
          <>
            <h1>Contact the organizers</h1>
            <p class="contact-subtitle">
              Have a question for <strong>{group.name}</strong>? Send them a message and they'll get back to you directly.
            </p>

            <form method="POST" class="contact-form">
              <input name="_hp" type="text" tabindex="-1" autocomplete="off" aria-hidden="true" class="hp-field" />
              <input name="_t" type="hidden" value={String(Date.now())} />

              {result?.type === "error" && (
                <div class="alert alert-error" role="alert">{result.message}</div>
              )}

              <div class="form-group">
                <label for="name">Your name *</label>
                <input id="name" name="name" type="text" placeholder="Taylor Kim" required />
              </div>

              <div class="form-group">
                <label for="email">Your email *</label>
                <input id="email" name="email" type="email" placeholder="taylor@example.com" required />
                <span class="form-hint">The organizers will reply to this address.</span>
              </div>

              <div class="form-group">
                <label for="message">Your question *</label>
                <textarea
                  id="message"
                  name="message"
                  rows={5}
                  placeholder="What would you like to know?"
                  required
                  maxlength={2000}
                />
              </div>

              <button type="submit" class="btn btn-primary btn-lg" style="width: 100%; justify-content: center;">
                Send message →
              </button>
            </form>
          </>
        )}
      </div>

      <aside class="contact-sidebar">
        <div class="group-card">
          <h3>{group.name}</h3>
          {(group.city || group.country) && (
            <p class="group-location">📍 {group.city}{group.region ? `, ${group.region}` : ""}{group.country ? `, ${group.country}` : ""}</p>
          )}
          <p>{descSnippet}</p>
          <a href={groupUrl(group)} class="btn btn-ghost btn-sm" style="margin-top: 0.75rem;">View group →</a>
        </div>
        <p class="contact-note">
          Your email is only shared with the group organizer. We don't use it for marketing. <a href="/privacy">Privacy policy →</a>
        </p>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .hp-field {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  .contact-page {
    padding: 2.5rem 0 4rem;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 2.5rem;
    align-items: start;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    text-decoration: none;
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .breadcrumb a:hover {
    color: var(--color-primary);
  }

  h1 {
    margin-bottom: 0.375rem;
  }

  .contact-subtitle {
    color: var(--color-text-muted);
    font-size: var(--size-lg);
    margin-bottom: 1.75rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 480px;
  }

  /* Closed state */
  .closed-state {
    padding: 2.5rem 2rem;
    background: #f9fafb;
    border: 2px solid #d1d5db;
    border-radius: var(--radius-lg);
    max-width: 480px;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .closed-state h1 {
    color: #374151;
    margin-bottom: 0;
  }

  .closed-state p {
    color: var(--color-text-muted);
  }

  /* Success state */
  .success-state {
    text-align: center;
    padding: 3rem 2rem;
    background: var(--color-surface);
    border: 2px solid var(--color-accent);
    border-radius: var(--radius-lg);
    max-width: 480px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .success-icon {
    font-size: 3rem;
  }

  .success-state h1 {
    margin-bottom: 0;
    color: var(--color-accent-dark);
  }

  .success-state p {
    color: var(--color-text-muted);
  }

  /* Sidebar */
  .contact-sidebar {
    position: sticky;
    top: 80px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .group-card {
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
  }

  .group-card h3 {
    font-size: var(--size-lg);
    margin-bottom: 0.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px dashed var(--color-border);
  }

  .group-location {
    font-size: var(--size-xs);
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
    max-width: none;
  }

  .group-card p {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
  }

  .contact-note {
    font-size: var(--size-xs);
    color: var(--color-text-light);
    text-align: center;
    max-width: none;
  }

  @media (max-width: 768px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }

    .contact-sidebar {
      position: static;
      order: -1;
    }
  }
</style>
