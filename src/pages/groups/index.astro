---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GroupCard from "../../components/groups/GroupCard.astro";
import { db, Groups, Meetups, count, eq, and, gte, asc } from "astro:db";
import { CATEGORIES, getCategoryLabel } from "../../lib/categories";

const today = new Date();
today.setHours(0, 0, 0, 0);

const activeCategory = Astro.url.searchParams.get("category")?.trim() ?? "";
const activeTag = Astro.url.searchParams.get("tag")?.trim() ?? "";

const allGroups = await db
  .select()
  .from(Groups)
  .where(eq(Groups.status, "approved"))
  .orderBy(asc(Groups.name));

// Categories that actually have groups
const presentCategorySlugs = new Set(allGroups.map(g => g.category).filter(Boolean));
const presentCategories = CATEGORIES.filter(c => presentCategorySlugs.has(c.slug));

// Collect unique tags from all groups
const allTags = Array.from(
  new Set(
    allGroups
      .flatMap(g => (g.tags ? g.tags.split(",").map(t => t.trim()).filter(Boolean) : []))
  )
).sort();

// Apply filters
let groups = activeCategory
  ? allGroups.filter(g => g.category === activeCategory)
  : allGroups;
if (activeTag) {
  groups = groups.filter(g => g.tags?.split(",").map(t => t.trim()).includes(activeTag));
}

const upcomingCounts: Record<string, number> = {};
for (const group of groups) {
  const result = await db
    .select({ val: count() })
    .from(Meetups)
    .where(and(eq(Meetups.groupId, group.id), gte(Meetups.date, today)));
  upcomingCounts[group.id] = result[0]?.val ?? 0;
}
---

<BaseLayout
  title="Find a Group"
  description="Discover communities on DevRel(ish) — in-person social gatherings for technical professionals at conferences and cities around the world."
>
  <section class="page-hero">
    <div class="container">
      <h1>Find a group</h1>
      <p>
        Communities for builders, creators, and practitioners — connecting in person at
        conferences, in cities, or wherever your people gather.
      </p>
    </div>
  </section>

  {(presentCategories.length > 0 || allTags.length > 0) && (
    <div class="filter-bar">
      <div class="container">

        {presentCategories.length > 0 && (
          <div class="filter-row">
            <span class="filter-label">Category:</span>
            <div class="filter-chips">
              <a href="/groups" class:list={["filter-chip", { active: !activeCategory }]}>All</a>
              {presentCategories.map(c => (
                <a
                  href={`/groups?category=${encodeURIComponent(c.slug)}`}
                  class:list={["filter-chip", { active: c.slug === activeCategory }]}
                >{c.label}</a>
              ))}
            </div>
          </div>
        )}

        {allTags.length > 0 && (
          <div class="filter-row">
            <span class="filter-label">Topic:</span>
            <div class="filter-chips">
              <a
                href={activeCategory ? `/groups?category=${encodeURIComponent(activeCategory)}` : "/groups"}
                class:list={["filter-chip", { active: !activeTag }]}
              >All</a>
              {allTags.map(tag => {
                const params = new URLSearchParams();
                if (activeCategory) params.set("category", activeCategory);
                params.set("tag", tag);
                return (
                  <a
                    href={`/groups?${params}`}
                    class:list={["filter-chip", { active: tag === activeTag }]}
                  >{tag}</a>
                );
              })}
            </div>
          </div>
        )}

      </div>
    </div>
  )}

  <section class="groups-section">
    <div class="container">
      {(activeCategory || activeTag) && (
        <p class="filter-notice">
          {activeCategory && <>Category: <strong>{getCategoryLabel(activeCategory) ?? activeCategory}</strong></>}
          {activeCategory && activeTag && " · "}
          {activeTag && <>Topic: <strong>{activeTag}</strong></>}
          {" · "}<a href="/groups">Clear filters</a>
        </p>
      )}

      {
        groups.length === 0 ? (
          <div class="empty-state">
            <div class="empty-icon" aria-hidden="true">◈</div>
            {(activeCategory || activeTag) ? (
              <>
                <h2>No groups match those filters</h2>
                <p><a href="/groups">Browse all groups</a> or start one!</p>
              </>
            ) : (
              <>
                <h2>No groups yet!</h2>
                <p>Be the first to start a group.</p>
                <a href="/groups/register" class="btn btn-primary">Start a group →</a>
              </>
            )}
          </div>
        ) : (
          <div class="groups-grid">
            {groups.map((g) => (
              <GroupCard
                id={g.id}
                name={g.name}
                slug={g.slug}
                city={g.city}
                region={g.region}
                country={g.country}
                tagline={g.tagline}
                category={g.category}
                tags={g.tags}
                description={g.description}
                upcomingCount={upcomingCounts[g.id]}
              />
            ))}
          </div>
        )
      }
    </div>
  </section>

  <section class="start-cta">
    <div class="container">
      <p>
        Want to organize gatherings for your community?{" "}
        <a href="/groups/register">Start a group →</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 3rem 0 2rem;
    background: var(--color-surface-warm);
    border-bottom: 2px solid var(--color-border);
  }

  .page-hero h1 {
    margin-bottom: 0.75rem;
  }

  .page-hero p {
    font-size: var(--size-lg);
    color: var(--color-text-muted);
    max-width: 56ch;
  }

  .filter-bar {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding: 0.75rem 0;
  }

  .filter-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding: 0.25rem 0;
  }

  .filter-row + .filter-row {
    border-top: 1px solid var(--color-border);
    margin-top: 0.5rem;
    padding-top: 0.625rem;
  }

  .filter-label {
    font-size: var(--size-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-light);
    flex-shrink: 0;
    min-width: 60px;
  }

  .filter-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .filter-chip {
    font-size: var(--size-xs);
    font-weight: 600;
    background: var(--color-surface-warm);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 0.2rem 0.7rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition), border-color var(--transition), background var(--transition);
  }

  .filter-chip:hover,
  .filter-chip.active {
    color: var(--color-primary);
    border-color: var(--color-primary);
    background: rgba(232, 112, 74, 0.06);
  }

  .groups-section {
    padding: 2.5rem 0;
  }

  .filter-notice {
    font-size: var(--size-sm);
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    max-width: none;
  }

  .groups-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    max-width: 400px;
    margin-inline: auto;
  }

  .empty-icon {
    font-size: 4rem;
    color: var(--color-primary);
    opacity: 0.3;
    margin-bottom: 1rem;
  }

  .empty-state h2 {
    margin-bottom: 0.5rem;
  }

  .empty-state p {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    max-width: none;
  }

  .start-cta {
    padding: 1.5rem 0 3rem;
    text-align: center;
  }

  .start-cta p {
    color: var(--color-text-muted);
    max-width: none;
  }
</style>
