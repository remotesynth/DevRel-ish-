---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GroupCard from "../../components/groups/GroupCard.astro";
import { db, Groups, Meetups, count, eq, and, gte, desc } from "astro:db";

const today = new Date();
today.setHours(0, 0, 0, 0);

const groups = await db
  .select()
  .from(Groups)
  .where(eq(Groups.status, "approved"))
  .orderBy(Groups.city);

const upcomingCounts: Record<string, number> = {};
for (const group of groups) {
  const result = await db
    .select({ val: count() })
    .from(Meetups)
    .where(and(eq(Meetups.groupId, group.id), gte(Meetups.date, today)));
  upcomingCounts[group.id] = result[0]?.val ?? 0;
}
---

<BaseLayout
  title="Find a Group"
  description="Discover DevRel(ish) groups in cities around the world — in-person social meetups for DevRel professionals."
>
  <section class="page-hero">
    <div class="container">
      <h1>Find a group near you</h1>
      <p>
        DevRel(ish) groups meet in person to connect, commiserate, and celebrate the weird wonderful
        world of developer relations. No agendas, no sponsors — just real people.
      </p>
    </div>
  </section>

  <section class="groups-section">
    <div class="container">
      {
        groups.length === 0 ? (
          <div class="empty-state">
            <div class="empty-icon" aria-hidden="true">◈</div>
            <h2>No groups yet!</h2>
            <p>Be the first to start a DevRel(ish) group in your city.</p>
            <a href="/groups/register" class="btn btn-primary">
              Start a group →
            </a>
          </div>
        ) : (
          <div class="groups-grid">
            {groups.map((g) => (
              <GroupCard
                id={g.id}
                name={g.name}
                slug={g.slug}
                city={g.city}
                region={g.region}
                country={g.country}
                description={g.description}
                upcomingCount={upcomingCounts[g.id]}
              />
            ))}
          </div>
        )
      }
    </div>
  </section>

  <section class="start-cta">
    <div class="container">
      <p>
        Don't see your city?{" "}
        <a href="/groups/register">Start a DevRel(ish) group →</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: 3rem 0 2rem;
    background: var(--color-surface-warm);
    border-bottom: 2px solid var(--color-border);
  }

  .page-hero h1 {
    margin-bottom: 0.75rem;
  }

  .page-hero p {
    font-size: var(--size-lg);
    color: var(--color-text-muted);
    max-width: 56ch;
  }

  .groups-section {
    padding: 2.5rem 0;
  }

  .groups-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .empty-state {
    text-align: center;
    padding: 4rem 2rem;
    max-width: 400px;
    margin-inline: auto;
  }

  .empty-icon {
    font-size: 4rem;
    color: var(--color-primary);
    opacity: 0.3;
    margin-bottom: 1rem;
  }

  .empty-state h2 {
    margin-bottom: 0.5rem;
  }

  .empty-state p {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    max-width: none;
  }

  .start-cta {
    padding: 1.5rem 0 3rem;
    text-align: center;
  }

  .start-cta p {
    color: var(--color-text-muted);
    max-width: none;
  }
</style>
