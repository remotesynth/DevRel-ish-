---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MeetupCard from "../../components/meetups/MeetupCard.astro";
import { db, Groups, Meetups, RSVPs, count, eq, and, gte, asc } from "astro:db";
import { renderMarkdown, stripMarkdown } from "../../lib/markdown";

const { slug } = Astro.params;

if (!slug) return Astro.redirect("/groups");

// Include closed groups so their pages remain accessible
const [group] = await db
  .select()
  .from(Groups)
  .where(and(eq(Groups.slug, slug)));

if (!group || (group.status !== "approved" && group.status !== "closed")) {
  return Astro.redirect("/groups");
}

const isGroupClosed = group.status === "closed";

const today = new Date();
today.setHours(0, 0, 0, 0);

const meetups = await db
  .select()
  .from(Meetups)
  .where(and(eq(Meetups.groupId, group.id), gte(Meetups.date, today)))
  .orderBy(asc(Meetups.date));

// RSVP counts per meetup
const rsvpCounts: Record<string, number> = {};
for (const meetup of meetups) {
  const result = await db
    .select({ val: count() })
    .from(RSVPs)
    .where(eq(RSVPs.meetupId, meetup.id));
  rsvpCounts[meetup.id] = result[0]?.val ?? 0;
}

const location = group.region
  ? `${group.city}, ${group.region}, ${group.country}`
  : `${group.city}, ${group.country}`;
---

<BaseLayout
  title={group.name}
  description={stripMarkdown(group.description).slice(0, 160)}
>
  <section class="group-hero">
    <div class="container">
      <div class="group-meta">
        <a href="/groups" class="back-link">← All groups</a>
        <span class="badge badge-approved">Active group</span>
      </div>
      <h1>
        {group.name}
        {isGroupClosed && <span class="badge badge-closed">Closed</span>}
      </h1>
      <p class="group-location">📍 {location}</p>
      {isGroupClosed && (
        <div class="closed-notice">
          This group is no longer active. Prior gathering pages remain available for reference.
        </div>
      )}
      <div class="group-desc prose" set:html={renderMarkdown(group.description)} />
      {!isGroupClosed && (
        <a href={`/groups/${group.slug}/contact`} class="contact-link">
          Have a question? Contact the organizers →
        </a>
      )}
    </div>
  </section>

  <section class="meetups-section">
    <div class="container">
      <h2>Upcoming gatherings</h2>

      {
        meetups.length === 0 ? (
          <div class="empty-meetups">
            <div class="empty-icon" aria-hidden="true">✦</div>
            <p>No gatherings scheduled yet. Check back soon!</p>
          </div>
        ) : (
          <div class="meetups-list">
            {meetups.map((m) => (
              <MeetupCard
                id={m.id}
                title={m.title}
                description={m.description}
                date={m.date}
                time={m.time}
                venue={m.venue}
                address={m.address}
                capacity={m.capacity}
                rsvpCount={rsvpCounts[m.id] ?? 0}
                groupSlug={group.slug}
                status={m.status}
                groupClosed={isGroupClosed}
              />
            ))}
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .group-hero {
    padding: 3rem 0 2rem;
    background: var(--color-surface-warm);
    border-bottom: 2px solid var(--color-border);
  }

  .group-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .back-link {
    font-size: var(--size-sm);
    font-weight: 600;
    text-decoration: none;
    color: var(--color-text-muted);
  }

  .back-link:hover {
    color: var(--color-primary);
  }

  h1 {
    margin-bottom: 0.375rem;
  }

  .group-location {
    font-size: var(--size-base);
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    max-width: none;
  }

  .group-desc {
    font-size: var(--size-lg);
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 64ch;
    margin-bottom: 1rem;
  }

  .group-desc :global(p) { margin-bottom: 0.75rem; }
  .group-desc :global(p:last-child) { margin-bottom: 0; }
  .group-desc :global(h1), .group-desc :global(h2), .group-desc :global(h3) {
    color: var(--color-text);
    margin: 1rem 0 0.375rem;
  }
  .group-desc :global(ul), .group-desc :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .group-desc :global(li) { margin-bottom: 0.25rem; }
  .group-desc :global(strong) { color: var(--color-text); }
  .group-desc :global(a) { color: var(--color-primary); }
  .group-desc :global(code) {
    font-family: var(--font-mono, monospace);
    font-size: 0.875em;
    background: var(--color-surface);
    padding: 0.1em 0.3em;
    border-radius: 3px;
  }
  .group-desc :global(blockquote) {
    border-left: 3px solid var(--color-border-strong);
    padding-left: 1rem;
    color: var(--color-text-light);
    font-style: italic;
    margin: 0.75rem 0;
  }

  .closed-notice {
    display: inline-block;
    font-size: var(--size-sm);
    font-weight: 600;
    color: #374151;
    background: #f3f4f6;
    border: 1.5px solid #d1d5db;
    border-radius: var(--radius-md);
    padding: 0.5rem 0.875rem;
    margin-bottom: 1rem;
    max-width: none;
  }

  .contact-link {
    display: inline-block;
    font-size: var(--size-sm);
    font-weight: 600;
    color: var(--color-text-muted);
    text-decoration: none;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-full);
    padding: 0.375rem 0.875rem;
    transition: color var(--transition), border-color var(--transition), background var(--transition);
  }

  .contact-link:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
    background: rgba(232, 112, 74, 0.06);
  }

  .meetups-section {
    padding: 2.5rem 0 4rem;
  }

  .meetups-section h2 {
    margin-bottom: 1.5rem;
  }

  .meetups-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 720px;
  }

  .empty-meetups {
    text-align: center;
    padding: 3rem 2rem;
    background: var(--color-surface);
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-lg);
    max-width: 400px;
  }

  .empty-icon {
    font-size: 3rem;
    color: var(--color-primary);
    opacity: 0.3;
    margin-bottom: 0.75rem;
  }

  .empty-meetups p {
    color: var(--color-text-muted);
    max-width: none;
  }
</style>
