# ── Required (dev + production) ───────────────────────────────────────────────

# Session encryption key. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Your site's public URL — no trailing slash.
# Dev:  http://localhost:4321
# Prod: https://your-site.netlify.app
BETTER_AUTH_URL=http://localhost:4321

# ── Production only (Turso database) ─────────────────────────────────────────
# Sign up at https://turso.tech, then:
#   turso db create devrelish
#   turso db show devrelish --url      → ASTRO_DB_REMOTE_URL
#   turso db tokens create devrelish   → ASTRO_DB_APP_TOKEN
#
# After setting these, push the schema once before your first deploy:
#   npm run db:push

ASTRO_DB_REMOTE_URL=
ASTRO_DB_APP_TOKEN=

# ── First-run admin setup ─────────────────────────────────────────────────────
# Set this to a strong random secret to enable the /setup page.
# Generate with: openssl rand -base64 24
# After creating your first admin at /setup, remove this variable
# from Netlify to permanently disable the setup page.

SETUP_TOKEN=
